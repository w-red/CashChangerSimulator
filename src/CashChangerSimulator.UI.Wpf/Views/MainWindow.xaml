<Window 
    x:Class="CashChangerSimulator.UI.Wpf.Views.MainWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
    xmlns:ctrl="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
    Title="CashChanger Simulator [LIVE]" 
    AutomationProperties.AutomationId="MainWindow"
    MinWidth="800" MinHeight="600"
    d:DesignWidth="1240" d:DesignHeight="820"
    Background="{DynamicResource MaterialDesign.Brush.Background}"
    Foreground="{DynamicResource MaterialDesign.Brush.OnBackground}"
    WindowStartupLocation="CenterScreen"
    TextElement.Foreground="{DynamicResource MaterialDesign.Brush.OnBackground}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="16"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto">
    
    <Window.Resources>
        <sys:Boolean x:Key="True">True</sys:Boolean>
        <sys:Boolean x:Key="False">False</sys:Boolean>
    </Window.Resources>

    <materialDesign:DialogHost x:Name="RootDialogHost" Identifier="RootDialog" Style="{StaticResource MaterialDesignEmbeddedDialogHost}"
                               AutomationProperties.AutomationId="MainDialogHost">
        <Grid>
            <Grid Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" MinWidth="300" />
                </Grid.ColumnDefinitions>
                
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header Dashboard -->
                <Border Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="24,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <!-- Left: Balance -->
                        <ctrl:BalanceDisplayControl x:Name="GlobalBalanceDisplay" DataContext="{Binding Dispense}" HorizontalAlignment="Left" />
                        
                        <!-- Right: Status / Mode / Jam -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                                <!-- Global Mode Indicator -->
                                <Border Background="{DynamicResource MaterialDesign.Brush.Primary}" 
                                        CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding GlobalModeName.Value}" Foreground="White" FontWeight="Bold" FontSize="11"
                                               AutomationProperties.AutomationId="ModeIndicatorText"/>
                                </Border>
                                <!-- Hardaware Status Indicators -->
                                <ctrl:StatusHeaderControl x:Name="GlobalStatusHeader" DataContext="{Binding Inventory}" />
                                

                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Area (Navigation Frame) -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2">
                    <Frame Name="MainFrame" NavigationUIVisibility="Hidden" />
                </Grid>
            </Grid>
        </Grid>
    </materialDesign:DialogHost>
</Window>
