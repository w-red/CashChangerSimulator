<Window 
    x:Class="CashChangerSimulator.UI.Wpf.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
    xmlns:ctrl="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
    Title="Cash Changer Simulator v1.1.0 (Componentized)" Height="820" Width="1240"
    Background="{StaticResource BackgroundBrush}"
    Foreground="{StaticResource OnBackgroundBrush}"
    WindowStartupLocation="CenterScreen"
    TextElement.Foreground="{StaticResource OnBackgroundBrush}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="13"
    TextOptions.TextFormattingMode="Ideal"
    TextOptions.TextRenderingMode="Auto">
    
    <Window.Resources>
        <sys:Boolean x:Key="True">True</sys:Boolean>
        <sys:Boolean x:Key="False">False</sys:Boolean>
    </Window.Resources>

    <Grid>
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>
            
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header Dashboard -->
            <Border Grid.ColumnSpan="2" Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="24,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <!-- Left: Balance -->
                    <ctrl:BalanceDisplayControl DataContext="{Binding Dispense}" HorizontalAlignment="Left" />
                    
                    <!-- Right: Status / Mode / Jam -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                            <!-- Global Mode Indicator -->
                            <Border Background="{StaticResource PrimaryBrush}" 
                                    CornerRadius="12" Padding="12,4" Margin="0,0,8,0"
                                    VerticalAlignment="Top">
                                <TextBlock Text="{Binding GlobalModeName.Value}" Foreground="White" FontWeight="Bold" FontSize="11"
                                           AutomationProperties.AutomationId="ModeIndicatorText"/>
                            </Border>
                            <!-- Hardaware Status Indicators -->
                            <ctrl:StatusHeaderControl DataContext="{Binding Inventory}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="1" Grid.ColumnSpan="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="340" />
                </Grid.ColumnDefinitions>
                
                <!-- Left: Inventory Tiles -->
                <ctrl:InventoryGridControl DataContext="{Binding Inventory}" />

                <!-- Right: Terminals & Activity -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- NEW: Terminal Launchers (Unified Mode) -->
                        <StackPanel Visibility="{Binding CurrentUIMode.Value, Converter={StaticResource UIModeVisibilityConv}, ConverterParameter=Standard}">
                            <Border Style="{StaticResource CardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="TERMINAL ACCESS" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Deposit Launcher -->
                                        <Button Grid.Column="0" 
                                                Style="{StaticResource PrimaryButtonStyle}" 
                                                Height="60" Margin="4"
                                                Command="{Binding OpenDepositCommand}"
                                                AutomationProperties.AutomationId="LaunchDepositButton">
                                            <StackPanel>
                                                <materialDesign:PackIcon Kind="ArrowDownBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24"/>
                                                <TextBlock Text="DEPOSIT" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                        
                                        <!-- Dispense Launcher -->
                                        <Button Grid.Column="1" 
                                                Style="{StaticResource PrimaryButtonStyle}" 
                                                Height="60" Margin="4"
                                                Background="{StaticResource SecondaryBrush}"
                                                BorderBrush="{StaticResource SecondaryBrush}"
                                                Command="{Binding OpenDispenseCommand}"
                                                AutomationProperties.AutomationId="LaunchDispenseButton">
                                            <StackPanel>
                                                <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24"/>
                                                <TextBlock Text="DISPENSE" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- POS TRANSACTION MODE (Remains integrated for workflow focus) -->
                        <StackPanel Visibility="{Binding CurrentUIMode.Value, Converter={StaticResource UIModeVisibilityConv}, ConverterParameter=PosTransaction}">
                            <ctrl:PosTransactionControl DataContext="{Binding PosTransaction}" Margin="0,0,0,16"/>
                        </StackPanel>
                        
                        <!-- Recent Transactions Activity Feed (Common) -->
                        <ctrl:ActivityFeedControl DataContext="{Binding Inventory}" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
