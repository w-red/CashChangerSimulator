<UserControl x:Class="CashChangerSimulator.UI.Wpf.Views.DepositActiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:DepositViewModel}"
             d:DesignHeight="500" d:DesignWidth="400">
    <StackPanel>
        <!-- Current Amount Display -->
        <Border Background="#0DFFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{StaticResource CurrentDeposit}" FontSize="10" FontWeight="Bold" 
                           Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding CurrencyPrefix.Value}" FontSize="20" VerticalAlignment="Bottom" Margin="0,0,4,8" Opacity="0.7"/>
                    <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat={}{0:N0}}"  
                               FontSize="40" FontWeight="Thin"
                               AutomationProperties.AutomationId="CurrentDepositText"/>
                    <TextBlock Text="{Binding CurrencySuffix.Value}" FontSize="20" VerticalAlignment="Bottom" Margin="4,0,0,8" Opacity="0.7"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Overflow & Reject Alerts -->
        <StackPanel Margin="0,0,0,16">
            <Border Background="Goldenrod" CornerRadius="4" Padding="8,4" Margin="0,0,0,4"
                    Visibility="{Binding HasOverflow.Value, Converter={StaticResource VisibilityConv}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Foreground="White" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="{StaticResource Overflow}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding CurrencyPrefix.Value}"/>
                        <Run Text="{Binding OverflowAmount.Value, StringFormat={}{0:N0}}"/>
                        <Run Text="{Binding CurrencySuffix.Value}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border Background="OrangeRed" CornerRadius="4" Padding="8,4"
                    Visibility="{Binding HasReject.Value, Converter={StaticResource VisibilityConv}}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="Cancel" Foreground="White" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Foreground="White" FontWeight="Bold" VerticalAlignment="Center">
                        <Run Text="{StaticResource Reject}"/>
                        <Run Text=": "/>
                        <Run Text="{Binding CurrencyPrefix.Value}"/>
                        <Run Text="{Binding RejectAmount.Value, StringFormat={}{0:N0}}"/>
                        <Run Text="{Binding CurrencySuffix.Value}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Main Actions (Not Fixed) -->
        <StackPanel Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BulkInsertButton"
                        Grid.Column="0" Style="{StaticResource SecondaryButtonStyle}" 
                        Command="{Binding ShowBulkInsertCommand}"
                        Margin="4" Height="40"
                        IsEnabled="{Binding IsDepositPaused.Value, Converter={StaticResource InverseBoolConverter}}"
                        AutomationProperties.AutomationId="BulkInsertButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlaylistPlus" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Bulk}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SimulateOverlapButton"
                        Grid.Column="1" Style="{StaticResource SecondaryButtonStyle}" 
                        Command="{Binding SimulateOverlapCommand}"
                        Margin="4" Height="40" Foreground="Orange"
                        ToolTip="Simulate Overlap Error"
                        AutomationProperties.AutomationId="SimulateOverlapButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LayersTripleOutline"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Overlap}"
                                   FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SimulateRejectButton"
                        Grid.Column="2" Style="{StaticResource SecondaryButtonStyle}" 
                        Command="{Binding SimulateRejectCommand}"
                        Margin="4" Height="40" Foreground="Goldenrod"
                        ToolTip="Simulate Reject"
                        AutomationProperties.AutomationId="SimulateRejectButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CashRemove"
                                                 Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Reject}"
                                   FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Button x:Name="FinishCountingButton"
                    Command="{Binding FixDepositCommand}" Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Stretch" Margin="4,4,4,12" Height="44"
                    AutomationProperties.AutomationId="FixDepositButton">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Check" Margin="0,0,12,0" />
                    <TextBlock Text="{StaticResource FinishCounting}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Pause/Resume/Store/Return -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <!-- Pause/Resume -->
                <Grid Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
                    <Button x:Name="PauseDepositButton" Style="{StaticResource SecondaryButtonStyle}" 
                            Command="{Binding PauseDepositCommand}"
                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource InvertedVisibilityConv}}"
                            Margin="4" Height="40"
                            AutomationProperties.AutomationId="PauseDepositButton">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pause" Margin="0,0,8,0"/>
                            <TextBlock Text="{StaticResource Pause}" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ResumeDepositButton" Style="{StaticResource PrimaryButtonStyle}" 
                            Command="{Binding ResumeDepositCommand}"
                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource VisibilityConv}}"
                            Margin="4" Height="40"
                            AutomationProperties.AutomationId="ResumeDepositButton">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0"/>
                            <TextBlock Text="{StaticResource Resume}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Store (Fixed state) -->
                <Button x:Name="StoreDepositButton"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding StoreDepositCommand}"
                        Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource VisibilityConv}}"
                        Margin="4" Height="44" AutomationProperties.AutomationId="StoreDepositButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Wallet" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Store}" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Button x:Name="RepayDepositButton" Style="{StaticResource SecondaryButtonStyle}" 
                        Command="{Binding CancelDepositCommand}"
                        Foreground="IndianRed"
                        Margin="4" Height="40"
                        AutomationProperties.AutomationId="RepayDepositButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cancel" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Return}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <!-- RESET ERROR during active session -->
                <Button x:Name="ActiveResetErrorButton" Command="{Binding ResetErrorCommand}"
                        Content="{StaticResource ResetError}"
                        Margin="4" Height="40"
                        AutomationProperties.AutomationId="ActiveResetErrorButton">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsJammed.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOverlapped.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDeviceError.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
