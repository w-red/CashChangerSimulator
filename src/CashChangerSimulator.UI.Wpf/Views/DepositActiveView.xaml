<UserControl x:Class="CashChangerSimulator.UI.Wpf.Views.DepositActiveView"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:DepositViewModel}"
              d:DesignHeight="750" d:DesignWidth="400">
    <UserControl.Resources>
        <!-- Logic for visibility and other view-specific resources can go here if needed -->
    </UserControl.Resources>

    <StackPanel>
        <!-- Current Amount Display -->
        <Border Background="#0DFFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <DockPanel LastChildFill="False">
                    <!-- Left: Required -->
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="{StaticResource RequiredAmountLabel}" FontSize="10" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,2"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrencyPrefix.Value}" FontSize="32" VerticalAlignment="Center" Opacity="0.7" Margin="0,0,4,0"/>
                            <TextBlock Text="{Binding RequiredAmountInput.Value, StringFormat={}{0:N0}}" 
                                       FontSize="32" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       AutomationProperties.AutomationId="RequiredAmountText"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Right: Remaining -->
                    <StackPanel DockPanel.Dock="Right">
                        <TextBlock Text="{StaticResource RemainingAmountLabel}" FontSize="10" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,2" HorizontalAlignment="Right"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CurrencyPrefix.Value}" FontSize="32" VerticalAlignment="Center" Opacity="0.7" Foreground="{DynamicResource App.Brush.AccentError}"/>
                            <TextBlock Text="{Binding RemainingAmount.Value, StringFormat={}{0:N0}}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource App.Brush.AccentError}"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>

                <!-- Alerts (Badge style) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <!-- Hardware Errors (Mirroring Main Window) -->
                    <Border Background="{DynamicResource App.Brush.Error}" Style="{StaticResource AlertBadgeStyle}"
                            Visibility="{Binding IsDeviceError.Value, Converter={StaticResource VisibilityConv}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircle" Foreground="White" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                <Run Text="{StaticResource ErrorDevicePrefix}"/><Run Text="{Binding CurrentErrorCode.Value}"/><Run Text="{StaticResource ErrorDeviceSuffix}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource App.Brush.Jam}" Style="{StaticResource AlertBadgeStyle}"
                            Visibility="{Binding IsJammed.Value, Converter={StaticResource VisibilityConv}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="White" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource StatusJam}" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource App.Brush.Overlap}" Style="{StaticResource AlertBadgeStyle}"
                            Visibility="{Binding IsOverlapped.Value, Converter={StaticResource VisibilityConv}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="LayersTripleOutline" Foreground="White" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{StaticResource StatusOverlap}" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Transaction Specific -->
                    <Border Background="{DynamicResource App.Brush.Warning}" Style="{StaticResource AlertBadgeStyle}"
                            Visibility="{Binding HasOverflow.Value, Converter={StaticResource VisibilityConv}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircleOutline" Foreground="White" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                <Run Text="{StaticResource Overflow}"/>
                                <Run Text="{Binding CurrencyPrefix.Value}"/><Run Text="{Binding OverflowAmount.Value, StringFormat={}{0:N0}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource App.Brush.Reject}" Style="{StaticResource AlertBadgeStyle}"
                            Visibility="{Binding HasReject.Value, Converter={StaticResource VisibilityConv}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Cancel" Foreground="White" Width="14" Height="14" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center">
                                <Run Text="{StaticResource Reject}"/>
                                <Run Text="{Binding CurrencyPrefix.Value}"/><Run Text="{Binding RejectAmount.Value, StringFormat={}{0:N0}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Separator Background="{DynamicResource MaterialDesign.Brush.Outline}" Margin="0,12" Opacity="0.3"/>

                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="{StaticResource CurrentDeposit}" FontSize="12" FontWeight="Bold" 
                               Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding CurrencyPrefix.Value}" FontSize="24" VerticalAlignment="Bottom" Margin="0,0,4,8" Opacity="0.7"/>
                        <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat={}{0:N0}}"  
                                   FontSize="32" FontWeight="Thin"
                                   AutomationProperties.AutomationId="CurrentDepositText"/>
                        <TextBlock Text="{Binding CurrencySuffix.Value}" FontSize="24" VerticalAlignment="Bottom" Margin="4,0,0,8" Opacity="0.7"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Escrow Breakdown -->
        <Border Background="#0DFFFFFF" CornerRadius="8" Padding="12" Margin="0,0,0,16"
                Visibility="{Binding CurrentDepositAmount.Value, Converter={StaticResource VisibilityConv}}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="4,0,0,8" Opacity="0.7">
                    <materialDesign:PackIcon Kind="History" Width="14" Height="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{StaticResource LabelPendingItems}" FontSize="10" FontWeight="Black" VerticalAlignment="Center"/>
                </StackPanel>
                
                <ItemsControl ItemsSource="{Binding EscrowDenominations.Value}" ItemTemplate="{StaticResource EscrowItemTemplate}" />
            </StackPanel>
        </Border>

        <!-- Main Actions (Not Fixed) -->
        <StackPanel Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
             <Button x:Name="BulkInsertButton"
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Command="{Binding ShowBulkInsertCommand}"
                    Margin="4,0,4,8" Height="44"
                    AutomationProperties.AutomationId="BulkInsertButton">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Plus" Margin="0,0,12,0" />
                    <TextBlock Text="{StaticResource BulkDeposit}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </Button>

            <Button x:Name="FinishCountingButton"
                    Command="{Binding FixDepositCommand}" Style="{StaticResource SecondaryButtonStyle}"
                    HorizontalAlignment="Stretch" Margin="4,4,4,12" Height="44"
                    AutomationProperties.AutomationId="FixDepositButton">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Check" Margin="0,0,12,0" />
                    <TextBlock Text="{StaticResource FinishCounting}" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" FontWeight="Bold" FontSize="14"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Pause/Resume/Store/Return -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <!-- Pause/Resume -->
                <Grid Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
                    <Button x:Name="PauseDepositButton" Style="{StaticResource SecondaryButtonStyle}" 
                            Command="{Binding PauseDepositCommand}"
                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource InvertedVisibilityConv}}"
                            Margin="4" Height="40"
                            AutomationProperties.AutomationId="PauseDepositButton">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Pause" Margin="0,0,8,0"/>
                            <TextBlock Text="{StaticResource Pause}" FontSize="12" FontWeight="Bold"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="ResumeDepositButton" Style="{StaticResource PrimaryButtonStyle}" 
                            Command="{Binding ResumeDepositCommand}"
                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource VisibilityConv}}"
                            Margin="4" Height="40"
                            AutomationProperties.AutomationId="ResumeDepositButton">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0"/>
                            <TextBlock Text="{StaticResource Resume}"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Store (Fixed state) -->
                <Button x:Name="StoreDepositButton"
                        Style="{StaticResource PrimaryButtonStyle}" 
                        Command="{Binding StoreDepositCommand}"
                        Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource VisibilityConv}}"
                        Margin="4" Height="44" AutomationProperties.AutomationId="StoreDepositButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Wallet" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Store}" FontSize="14"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Button x:Name="RepayDepositButton" Style="{StaticResource SecondaryButtonStyle}" 
                        Command="{Binding CancelDepositCommand}"
                        Foreground="IndianRed"
                        Margin="4" Height="40"
                        AutomationProperties.AutomationId="RepayDepositButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cancel" Margin="0,0,8,0" />
                        <TextBlock Text="{StaticResource Return}" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                </Button>
                <!-- RESET ERROR during active session -->
                <Button x:Name="ActiveResetErrorButton" Command="{Binding ResetErrorCommand}"
                        Content="{StaticResource ResetError}"
                        Margin="4" Height="40"
                        AutomationProperties.AutomationId="ActiveResetErrorButton">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ErrorResetButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsJammed.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOverlapped.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDeviceError.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Simulation Actions (Bottom) -->
        <Border Margin="0,24,0,0" Padding="0,16,0,0" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource MaterialDesign.Brush.Outline}" Opacity="0.5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="SimulateJamButton"
                        Grid.Column="0"
                        Command="{Binding SimulateJamCommand}"
                        AutomationProperties.AutomationId="SimulateJamButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource Jam}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SimulationErrorButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsJammed.Value}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource App.Brush.Jam}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Jam}" />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="SimulateOverlapButton"
                        Grid.Column="1"
                        Command="{Binding SimulateOverlapCommand}"
                        AutomationProperties.AutomationId="SimulateOverlapButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="LayersTripleOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{StaticResource Overlap}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SimulationErrorButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverlapped.Value}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource App.Brush.Overlap}" />
                                    <Setter Property="Foreground" Value="White" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Overlap}" />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="SimulateErrorButton"
                        Grid.Column="2"
                        Command="{Binding SimulateDeviceErrorCommand}"
                        ToolTip="{StaticResource ToolTipSimulateError}"
                        AutomationProperties.AutomationId="SimulateDeviceErrorButton">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircleOutline" Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="ERR" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SimulationErrorButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDeviceError.Value}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource App.Brush.Warning}" />
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource App.Brush.Warning}" />
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
