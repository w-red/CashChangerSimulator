<Page x:Class="CashChangerSimulator.UI.Wpf.Views.PosMainPage"
      x:ClassModifier="internal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
      xmlns:ctrl="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
      d:DesignHeight="600" d:DesignWidth="1200"
      Title="{StaticResource TitleMainWindow}">
    <Grid Margin="24,0">
        <ctrl:PosTransactionControl DataContext="{Binding PosTransaction}"/>
    </Grid>
</Page>
