<Window 
    x:Class="CashChangerSimulator.UI.Wpf.Views.AdvancedSimulationWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
    mc:Ignorable="d"
    Background="{DynamicResource MaterialDesign.Brush.SurfaceContainer}"
    Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="13"
    TextOptions.TextFormattingMode="Ideal" 
    TextOptions.TextRenderingMode="Auto"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Title="{StaticResource AdvancedSimulationTitle}" 
    Height="800" Width="600"
    Topmost="True"
    AutomationProperties.AutomationId="AdvancedSimulationWindow"
    WindowStartupLocation="CenterScreen">
    <materialDesign:Card Margin="16">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{StaticResource AdvancedSimulationTitle}" 
                           Style="{StaticResource MaterialDesignHeadlineSmallTextBlock}"
                           FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock Text="{StaticResource AdvancedSimulationSubtitle}" 
                           Style="{StaticResource MaterialDesignBodySmallTextBlock}"
                           Opacity="0.7"/>
            </StackPanel>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Simulation Controls -->
                    <RowDefinition Height="Auto"/> <!-- Scripting -->
                    <RowDefinition Height="*"/>    <!-- Status lists -->
                </Grid.RowDefinitions>
                
                <!-- Simulation Controls -->
                <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,16" Background="{DynamicResource MaterialDesign.Brush.SurfaceContainerHigh}">
                    <StackPanel>
                        <TextBlock Text="{StaticResource ErrorSimulationTitle}" Style="{StaticResource MaterialDesignTitleLargeTextBlock}" Margin="0,0,0,16"/>
                        
                        <WrapPanel Orientation="Horizontal">
                            <Button Content="{StaticResource SimulateJam}" 
                                    Command="{Binding SimulateJamCommand}"
                                    AutomationProperties.AutomationId="SimulateJamButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource App.Brush.Jam}" BorderBrush="{DynamicResource App.Brush.Jam}"
                                    Margin="0,0,8,8"/>
                            <Button Content="{StaticResource SimulateOverlap}" 
                                    Command="{Binding SimulateOverlapCommand}"
                                    AutomationProperties.AutomationId="SimulateOverlapButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource App.Brush.Overlap}" BorderBrush="{DynamicResource App.Brush.Overlap}"
                                    Margin="0,0,8,8"/>
                            <Button Content="{StaticResource SimulateDeviceError}" 
                                    Command="{Binding SimulateDeviceErrorCommand}"
                                    AutomationProperties.AutomationId="SimulateDeviceErrorButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="{DynamicResource App.Brush.Warning}" BorderBrush="{DynamicResource App.Brush.Warning}" Foreground="Black"
                                    Margin="0,0,8,8"/>
                            <Button Content="{StaticResource Reset}" 
                                    Command="{Binding ResetErrorCommand}"
                                    AutomationProperties.AutomationId="ResetErrorButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Margin="0,0,8,8"/>
                        </WrapPanel>

                        <!-- Status Display -->
                        <StackPanel Margin="0,16,0,0">
                            <materialDesign:Chip Visibility="{Binding IsJammed.Value, Converter={StaticResource BoolToVis}}"
                                               Background="{DynamicResource App.Brush.Jam}" Foreground="White" Margin="0,4">
                                <materialDesign:Chip.Icon>
                                    <materialDesign:PackIcon Kind="AlertCircle"/>
                                </materialDesign:Chip.Icon>
                                <TextBlock Text="{StaticResource StatusJamDetected}" AutomationProperties.AutomationId="JamIndicatorText"/>
                            </materialDesign:Chip>
                            
                            <materialDesign:Chip Visibility="{Binding IsOverlapped.Value, Converter={StaticResource BoolToVis}}"
                                               Background="{DynamicResource App.Brush.Overlap}" Foreground="White" Margin="0,4">
                                <TextBlock Text="{StaticResource StatusOverlapDetected}" AutomationProperties.AutomationId="OverlapIndicatorText"/>
                            </materialDesign:Chip>
                            
                            <materialDesign:Chip Visibility="{Binding IsDeviceError.Value, Converter={StaticResource BoolToVis}}"
                                               Background="{DynamicResource App.Brush.Warning}" Foreground="Black" Margin="0,4">
                                <TextBlock Text="{StaticResource StatusDeviceError}" AutomationProperties.AutomationId="DeviceErrorIndicatorText"/>
                            </materialDesign:Chip>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Scripting Area -->
                <materialDesign:Card Grid.Row="1" Padding="16" Margin="0,0,0,16" Background="{DynamicResource MaterialDesign.Brush.SurfaceContainerHigh}">
                    <StackPanel>
                        <TextBlock Text="{StaticResource ScriptExecutionTitle}" Style="{StaticResource MaterialDesignTitleMediumTextBlock}" Margin="0,0,0,8"/>
                        <TextBox x:Name="ScriptInputTextBox" 
                                 AutomationProperties.AutomationId="ScriptInputTextBox"
                                 Text="{Binding ScriptInput.Value, UpdateSourceTrigger=PropertyChanged}"
                                 Height="80" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                 Style="{DynamicResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,0,8"/>
                        <Button x:Name="ExecuteScriptButton"
                                AutomationProperties.AutomationId="ExecuteScriptButton"
                                Content="{StaticResource Execute}"
                                Command="{Binding ExecuteScriptCommand}"
                                Style="{StaticResource MaterialDesignFlatButton}"
                                HorizontalAlignment="Right"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Lists -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="12" Background="{DynamicResource MaterialDesign.Brush.SurfaceContainerHigh}">
                       <StackPanel>
                           <TextBlock Text="{StaticResource LabelBillsUnit}" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                           <ItemsControl ItemsSource="{Binding Bills}">
                               <ItemsControl.ItemTemplate>
                                   <DataTemplate>
                                       <ToggleButton Content="{Binding Name}" Margin="2" 
                                                     IsChecked="{Binding IsInError}" 
                                                     Style="{StaticResource MaterialDesignActionToggleButton}"/>
                                   </DataTemplate>
                               </ItemsControl.ItemTemplate>
                           </ItemsControl>
                       </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="8,0,0,0" Padding="12" Background="{DynamicResource MaterialDesign.Brush.SurfaceContainerHigh}">
                        <StackPanel>
                            <TextBlock Text="{StaticResource LabelCoinsUnit}" FontWeight="Bold" Margin="0,0,0,8" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                            <ItemsControl ItemsSource="{Binding Coins}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Content="{Binding Name}" Margin="2" 
                                                      IsChecked="{Binding IsInError}" 
                                                      Style="{StaticResource MaterialDesignActionToggleButton}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="{StaticResource Close}" 
                        IsCancel="True"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding CloseCommand}"
                        Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</Window>
