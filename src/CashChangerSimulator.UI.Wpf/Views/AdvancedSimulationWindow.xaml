<Window x:Class="CashChangerSimulator.UI.Wpf.Views.AdvancedSimulationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
        mc:Ignorable="d"
        Title="{StaticResource AdvancedSimulation}" Height="500" Width="400"
        AutomationProperties.AutomationId="AdvancedSimulationWindow"
        Background="{StaticResource BackgroundBrush}"
        TextElement.Foreground="{StaticResource TextPrimaryBrush}"
        WindowStartupLocation="CenterOwner">
    
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConv" />
    </Window.Resources>
    
    <Border Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="{StaticResource AdvancedSimulation}" 
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="Black"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Settings Section -->
                    <Border Style="{StaticResource CardStyle}" Background="#05FFFFFF" Margin="0,0,0,16" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{StaticResource UposConfig}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                <TextBlock Text="{StaticResource RealTimeData}" VerticalAlignment="Center" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" 
                                           IsChecked="{Binding IsRealTimeDataEnabled.Value}" 
                                           Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                           ToolTip="{StaticResource RealTimeData}" />
                        </Grid>
                    </Border>

                    <!-- Status Section (During Deposit) -->
                    <Border Style="{StaticResource CardStyle}" Background="#106200EE" Margin="0,0,0,16" Padding="12"
                            Visibility="{Binding IsDepositInProgress.Value, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="{StaticResource CurrentDeposit}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CurrencyPrefix.Value}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                            <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat='{}{0:N0}'}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                            <TextBlock Text="{Binding CurrencySuffix.Value}" Foreground="{StaticResource PrimaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" Margin="4,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Error Status Indicators -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16" HorizontalAlignment="Left">
                        <Border x:Name="JamIndicator" Background="#F44336" CornerRadius="4" Padding="8,4" Margin="0,0,10,0"
                                Visibility="{Binding IsJammed.Value, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.AutomationId="JamIndicator">
                            <TextBlock Text="JAM" Foreground="White" FontWeight="Bold" AutomationProperties.AutomationId="JamIndicatorText"/>
                        </Border>
                        <Border x:Name="OverlapIndicator" Background="#FF9800" CornerRadius="4" Padding="8,4" Margin="0,0,10,0"
                                Visibility="{Binding IsOverlapped.Value, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.AutomationId="OverlapIndicator">
                            <TextBlock Text="OVERLAP" Foreground="White" FontWeight="Bold" AutomationProperties.AutomationId="OverlapIndicatorText"/>
                        </Border>
                        <Border x:Name="ErrorIndicator" Background="#9C27B0" CornerRadius="4" Padding="8,4"
                                Visibility="{Binding IsDeviceError.Value, Converter={StaticResource BoolToVis}}"
                                AutomationProperties.AutomationId="ErrorIndicator">
                            <TextBlock Text="DEVICE ERROR" Foreground="White" FontWeight="Bold" AutomationProperties.AutomationId="ErrorIndicatorText"/>
                        </Border>
                    </StackPanel>

                    <!-- Simulation Presets -->
                    <Border Style="{StaticResource CardStyle}"
                            Background="#05FFFFFF" Margin="0,0,0,16" Padding="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="SimulateJamButton"
                                        Content="Jam"
                                        Command="{Binding SimulateJamCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Height="32"
                                        FontSize="12"
                                        AutomationProperties.AutomationId="SimulateJamButton"/>
                                <Button x:Name="SimulateOverlapButton"
                                        Content="Overlap"
                                        Command="{Binding SimulateOverlapCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,4,0"
                                        Padding="10,4"
                                        Height="32"
                                        FontSize="12"
                                        AutomationProperties.AutomationId="SimulateOverlapButton"/>
                                <Button x:Name="SimulateDeviceErrorButton"
                                        Content="Error"
                                        Command="{Binding SimulateDeviceErrorCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,0,0,0"
                                        Padding="10,4"
                                        Height="32"
                                        FontSize="12"
                                        AutomationProperties.AutomationId="SimulateDeviceErrorButton" />
                            </StackPanel>
                            <Button x:Name="ResetErrorButton" Grid.Column="1"
                                    Content="Reset All" 
                                    Command="{Binding ResetErrorCommand}" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Padding="16,4"
                                    Height="36"
                                    AutomationProperties.AutomationId="ResetErrorButton"/>
                        </Grid>
                    </Border>

                    <!-- Scripts Section -->
                    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SurfaceBrush}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{StaticResource ScriptInput}" FontSize="11" FontWeight="Black" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                            
                            <TextBox x:Name="ScriptInputTextBox"
                                     Text="{Binding ScriptInput.Value, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     AutomationProperties.Name="ScriptInputTextBox"
                                     AutomationProperties.AutomationId="ScriptInputTextBox"
                                     materialDesign:HintAssist.Hint="{StaticResource ScriptInput}"
                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="150" FontFamily="Consolas" Margin="0,0,0,8"/>
                            
                            <TextBlock Text="{Binding ScriptError.Value}" Foreground="{StaticResource ErrorBrush}" 
                                       Visibility="{Binding ScriptError.Value, Converter={StaticResource StringNullOrEmptyToVisibilityConv}}" 
                                       FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            
                            <Button x:Name="ExecuteScriptButton"
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Content="{StaticResource Execute}" 
                                    AutomationProperties.AutomationId="ExecuteScriptButton"
                                    Command="{Binding ExecuteScriptCommand}" 
                                    HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
