<Window 
    x:Class="CashChangerSimulator.UI.Wpf.Views.AdvancedSimulationWindow"
    x:ClassModifier="internal"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
    mc:Ignorable="d"
    Background="#121212"
    Foreground="White"
    TextElement.FontWeight="Regular"
    TextElement.FontSize="13"
    TextOptions.TextFormattingMode="Ideal" 
    TextOptions.TextRenderingMode="Auto"
    FontFamily="{materialDesign:MaterialDesignFont}"
    Title="Advanced Simulation (Debug Mode)" 
    Height="800" Width="600"
    AutomationProperties.AutomationId="AdvancedSimulationWindow"
    WindowStartupLocation="CenterScreen">
    <materialDesign:Card Margin="16" materialDesign:ElevationAssist.Elevation="Dp8" Background="#121212" Foreground="White">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="アドバンスド・シミュレーション" 
                           Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                           FontWeight="Bold" Foreground="#BB86FC"/>
                <TextBlock Text="各デバイスのエラー状態を個別にシミュレートします" 
                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                           Opacity="0.7" Foreground="White"/>
            </StackPanel>

            <!-- Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Simulation Controls -->
                    <RowDefinition Height="*"/>    <!-- Status lists -->
                </Grid.RowDefinitions>
                
                <!-- Simulation Controls -->
                <materialDesign:Card Grid.Row="0" Padding="16" Margin="0,0,0,16" Background="#1E1E1E">
                    <StackPanel>
                        <TextBlock Text="エラー・シミュレーション" Style="{StaticResource MaterialDesignHeadline6TextBlock}" Margin="0,0,0,16" Foreground="White"/>
                        
                        <WrapPanel Orientation="Horizontal">
                            <Button Content="ジャム発生" 
                                    Command="{Binding SimulateJamCommand}"
                                    AutomationProperties.AutomationId="SimulateJamButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#D62828" BorderBrush="#D62828"
                                    Margin="0,0,8,8"/>
                            <Button Content="重なり発生" 
                                    Command="{Binding SimulateOverlapCommand}"
                                    AutomationProperties.AutomationId="SimulateOverlapButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#F77F00" BorderBrush="#F77F00"
                                    Margin="0,0,8,8"/>
                            <Button Content="デバイスエラー" 
                                    Command="{Binding SimulateDeviceErrorCommand}"
                                    AutomationProperties.AutomationId="SimulateDeviceErrorButton"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#FCBF49" BorderBrush="#FCBF49" Foreground="Black"
                                    Margin="0,0,8,8"/>
                            <Button Content="リセット" 
                                    Command="{Binding ResetErrorCommand}"
                                    AutomationProperties.AutomationId="ResetErrorButton"
                                    Style="{StaticResource MaterialDesignRaisedAccentButton}"
                                    Margin="0,0,8,8"/>
                        </WrapPanel>

                        <!-- Status Display -->
                        <StackPanel Margin="0,16,0,0">
                            <materialDesign:Chip Content="ジャム検出中" 
                                               AutomationProperties.AutomationId="JamIndicatorText"
                                               Visibility="{Binding IsJammed.Value, Converter={StaticResource BoolToVis}}"
                                               Background="#D62828" Foreground="White" Margin="0,4">
                                <materialDesign:Chip.Icon>
                                    <materialDesign:PackIcon Kind="AlertCircle"/>
                                </materialDesign:Chip.Icon>
                            </materialDesign:Chip>
                            
                            <materialDesign:Chip Content="重なり検出中" 
                                               Visibility="{Binding IsOverlapped.Value, Converter={StaticResource BoolToVis}}"
                                               Background="#F77F00" Foreground="White" Margin="0,4"/>

                            <materialDesign:Chip Content="デバイスエラー" 
                                               Visibility="{Binding IsDeviceError.Value, Converter={StaticResource BoolToVis}}"
                                               Background="#FCBF49" Foreground="Black" Margin="0,4"/>
                        </StackPanel>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Lists -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <materialDesign:Card Grid.Column="0" Margin="0,0,8,0" Padding="12" Background="#1E1E1E">
                       <StackPanel>
                           <TextBlock Text="紙幣ユニット" FontWeight="Bold" Margin="0,0,0,8" Foreground="#03DAC6"/>
                           <ItemsControl ItemsSource="{Binding Bills}">
                               <ItemsControl.ItemTemplate>
                                   <DataTemplate>
                                       <ToggleButton Content="{Binding Name}" Margin="2" 
                                                     IsChecked="{Binding IsInError}" 
                                                     Style="{StaticResource MaterialDesignActionLightToggleButton}"/>
                                   </DataTemplate>
                               </ItemsControl.ItemTemplate>
                           </ItemsControl>
                       </StackPanel>
                    </materialDesign:Card>

                    <materialDesign:Card Grid.Column="1" Margin="8,0,0,0" Padding="12" Background="#1E1E1E">
                        <StackPanel>
                            <TextBlock Text="硬貨ユニット" FontWeight="Bold" Margin="0,0,0,8" Foreground="#03DAC6"/>
                            <ItemsControl ItemsSource="{Binding Coins}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton Content="{Binding Name}" Margin="2" 
                                                      IsChecked="{Binding IsInError}" 
                                                      Style="{StaticResource MaterialDesignActionLightToggleButton}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>
            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,24,0,0">
                <Button Content="閉じる" 
                        IsCancel="True"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding CloseCommand}"
                        Foreground="#BB86FC"/>
            </StackPanel>
        </Grid>
    </materialDesign:Card>
</Window>
