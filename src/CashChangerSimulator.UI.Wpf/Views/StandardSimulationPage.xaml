<Page x:Class="CashChangerSimulator.UI.Wpf.Views.StandardSimulationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
      xmlns:ctrl="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
      d:DesignHeight="820" d:DesignWidth="1240"
      Title="StandardSimulationPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" />
            <ColumnDefinition x:Name="SidebarColumn"
                              Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>
        
        <!-- Left: Inventory Tiles (Explicit Column) -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <ctrl:InventoryGridControl DataContext="{Binding Inventory}" />
        </Grid>

        <!-- Right: Terminals & Activity -->
        <ScrollViewer x:Name="SidebarContent" Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,24,0">
                <!-- Terminal Launchers -->
                <Border Style="{StaticResource CardStyle}" Background="{StaticResource SurfaceBrush}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="{StaticResource TerminalAccess}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Row="0" Grid.Column="0" 
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Height="60" Margin="4"
                                    Background="#0A8F08" BorderBrush="#0A8F08"
                                    Command="{Binding OpenDepositCommand}"
                                    IsEnabled="{Binding Inventory.IsConnected.Value}"
                                    AutomationProperties.AutomationId="LaunchDepositButton">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="ArrowDownBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24" Foreground="White"/>
                                    <TextBlock Text="{StaticResource Deposit}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="White"/>
                                </StackPanel>
                            </Button>
                            
                            <Button Grid.Row="0" Grid.Column="1" 
                                    Style="{StaticResource PrimaryButtonStyle}" 
                                    Height="60" Margin="4"
                                    Background="#6200EE" BorderBrush="#6200EE"
                                    Command="{Binding OpenDispenseCommand}"
                                    IsEnabled="{Binding Inventory.IsConnected.Value}"
                                    AutomationProperties.AutomationId="LaunchDispenseButton">
                                <StackPanel>
                                    <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24" Foreground="White"/>
                                    <TextBlock Text="{StaticResource Dispense}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="1" Grid.ColumnSpan="2"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Background="#37474F" BorderBrush="#37474F"
                                    Height="50" Margin="4,8,4,4"
                                    Command="{Binding OpenAdvancedSimulationCommand}"
                                    IsEnabled="{Binding Inventory.IsConnected.Value}"
                                    AutomationProperties.AutomationId="LaunchAdvancedSimulationButton">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Terminal" Width="20" Height="20" Margin="0,0,8,0" Foreground="White"/>
                                    <TextBlock Text="{StaticResource AdvancedSimulation}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                                </StackPanel>
                            </Button>

                            <!-- Open/Close Device Buttons -->
                            <Button Grid.Row="2" Grid.Column="0"
                                    Style="{StaticResource TagButtonStyle}"
                                    Height="40" Margin="4,8,4,4"
                                    Background="{StaticResource PrimaryBrush}"
                                    Foreground="Black"
                                    Command="{Binding Inventory.OpenCommand}"
                                    Visibility="{Binding Inventory.IsConnected.Value, Converter={StaticResource InvertedVisibilityConv}}"
                                    AutomationProperties.AutomationId="DeviceOpenButton">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Power" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="{StaticResource Open}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Row="2" Grid.ColumnSpan="2"
                                    Style="{StaticResource TagButtonStyle}"
                                    Height="40" Margin="4,8,4,4"
                                    Background="#B0BEC5"
                                    Foreground="Black"
                                    Command="{Binding Inventory.CloseCommand}"
                                    Visibility="{Binding Inventory.IsConnected.Value, Converter={StaticResource VisibilityConv}}"
                                    AutomationProperties.AutomationId="DeviceCloseButton">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="PowerOff" Width="18" Height="18" Margin="0,0,6,0"/>
                                    <TextBlock Text="{StaticResource Close}" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Recent Transactions Activity Feed -->
                <ctrl:ActivityFeedControl DataContext="{Binding Inventory}" Margin="0,0,0,16" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
