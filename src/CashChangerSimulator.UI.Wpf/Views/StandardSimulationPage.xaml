<Page x:Class="CashChangerSimulator.UI.Wpf.Views.StandardSimulationPage"
      x:ClassModifier="internal"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
      xmlns:ctrl="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      mc:Ignorable="d" 
      d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
      d:DesignHeight="820" d:DesignWidth="1240"
      Title="StandardSimulationPage">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*" />
            <ColumnDefinition x:Name="SidebarColumn"
                              Width="*" MinWidth="300" />
        </Grid.ColumnDefinitions>
        
        <!-- Left: Inventory Tiles (Explicit Column) -->
        <Grid Grid.Column="0" Margin="0,0,12,0">
            <ctrl:InventoryGridControl DataContext="{Binding Inventory}" />
        </Grid>

        <!-- Right: Terminals & Activity -->
        <Grid x:Name="SidebarContent" Grid.Column="1" Margin="0,0,24,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Terminal Launchers (Fixed) -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}" Background="{DynamicResource MaterialDesign.Brush.Surface}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{StaticResource TerminalAccess}" FontSize="11" Foreground="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}" FontWeight="Black" Margin="0,0,0,16"/>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        
                        <Button x:Name="LaunchDepositButton"
                                Grid.Row="0" Grid.Column="0" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Height="60" Margin="4"
                                Background="{DynamicResource MaterialDesign.Brush.Primary}" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                Command="{Binding OpenDepositCommand}"
                                AutomationProperties.AutomationId="LaunchDepositButton">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ArrowDownBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24" Foreground="White"/>
                                <TextBlock Text="{StaticResource Deposit}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="LaunchDispenseButton"
                                Grid.Row="0" Grid.Column="1" 
                                Style="{StaticResource PrimaryButtonStyle}" 
                                Height="60" Margin="4"
                                Background="{DynamicResource MaterialDesign.Brush.Secondary}" BorderBrush="{DynamicResource MaterialDesign.Brush.Secondary}"
                                Command="{Binding OpenDispenseCommand}"
                                AutomationProperties.AutomationId="LaunchDispenseButton">
                            <StackPanel>
                                <materialDesign:PackIcon Kind="ArrowUpBoldCircleOutline" HorizontalAlignment="Center" Width="24" Height="24" Foreground="White"/>
                                <TextBlock Text="{StaticResource Dispense}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,0" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="LaunchAdvancedSimulationButton"
                                Grid.Row="1" Grid.ColumnSpan="2"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Background="{DynamicResource MaterialDesign.Brush.SurfaceVariant}" BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}"
                                Height="50" Margin="4,8,4,4"
                                Command="{Binding OpenAdvancedSimulationCommand}"
                                AutomationProperties.AutomationId="LaunchAdvancedSimulationButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Terminal" Width="20" Height="20" Margin="0,0,8,0" Foreground="White"/>
                                <TextBlock Text="{StaticResource AdvancedSimulation}" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" Foreground="White"/>
                            </StackPanel>
                        </Button>

                        <!-- Open/Close Device Buttons -->
                        <Button x:Name="DeviceOpenButton"
                                Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource TagButtonStyle}"
                                Height="40" Margin="4,8,4,4"
                                Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                Foreground="Black"
                                Command="{Binding Inventory.OpenCommand}"
                                Visibility="{Binding Inventory.IsConnected.Value, Converter={StaticResource InvertedVisibilityConv}}"
                                AutomationProperties.AutomationId="DeviceOpenButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Power" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="{StaticResource Open}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="DeviceCloseButton"
                                Grid.Row="2" Grid.Column="1"
                                Style="{StaticResource TagButtonStyle}"
                                Height="40" Margin="4,8,4,4"
                                Background="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}"
                                Foreground="Black"
                                Command="{Binding Inventory.CloseCommand}"
                                Visibility="{Binding Inventory.IsConnected.Value, Converter={StaticResource VisibilityConv}}"
                                AutomationProperties.AutomationId="DeviceCloseButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PowerOff" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="{StaticResource Close}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Recent Transactions Activity Feed (Scrollable Area) -->
            <ctrl:ActivityFeedControl Grid.Row="1" DataContext="{Binding Inventory}" Margin="0,0,0,16" VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Page>
