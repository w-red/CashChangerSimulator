<Window x:Class="CashChangerSimulator.UI.Wpf.Views.BulkAmountInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        Title="BULK INPUT" Height="450" Width="380"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="BulkAmountInputWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.Foreground="{StaticResource OnBackgroundBrush}"
        ResizeMode="NoResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Templates.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" Text="{StaticResource StrBulkInput}" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontWeight="Black"/>
            <TextBlock x:Name="SubtitleText" Text="{StaticResource StrBulkInputDefaultSubtitle}" FontSize="11" Opacity="0.4" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Items}"
                               ItemTemplate="{StaticResource BulkInputItemTemplate}">
                </ItemsControl>
                
                <!-- Error Simulation in Bulk Window -->
                <Separator Margin="0,16,0,8" Opacity="0.1"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding SimulateOverlapCommand}"
                            Content="SIM OVERLAP" Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="10" Height="24" Padding="8,0" Margin="4,0"
                            Foreground="Orange" BorderBrush="Orange"/>
                    <Button Command="{Binding SimulateJamCommand}"
                            Content="SIM JAM" Style="{StaticResource MaterialDesignOutlinedButton}"
                            FontSize="10" Height="24" Padding="8,0" Margin="4,0"
                            Foreground="Orange" BorderBrush="Orange"/>
                    <Button Command="{Binding ResetErrorCommand}"
                            Content="RESET"
                            FontSize="10" Height="24" Padding="8,0" Margin="4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsJammed.Value}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsOverlapped.Value}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{StaticResource StrCancel}" Click="CancelButton_Click" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Margin="0,0,12,0" 
                    AutomationProperties.AutomationId="BulkCancelButton"
                    Width="100" Height="40"/>
            <Button x:Name="ConfirmButton" Content="{StaticResource StrOk}" Click="OkButton_Click" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    AutomationProperties.AutomationId="BulkConfirmButton"
                    Width="auto" Height="40"/>
        </StackPanel>
    </Grid>
</Window>
