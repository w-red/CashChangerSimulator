<Window x:Class="CashChangerSimulator.UI.Wpf.Views.BulkAmountInputWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        Title="BULK INPUT" Height="680" Width="440"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="BulkAmountInputWindow"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Templates.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock x:Name="TitleText" Text="{StaticResource BulkInput}" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       Foreground="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}"
                       FontWeight="Black"/>
            <TextBlock x:Name="SubtitleText" Text="{StaticResource BulkInputDefaultSubtitle}" FontSize="11" Opacity="0.4" Margin="0,2,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,12" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}"
                           ItemTemplate="{StaticResource BulkInputItemTemplate}"/>
        </ScrollViewer>

        <!-- Error Simulation (Fixed Position) -->
        <Border Grid.Row="2" Background="#0DFFFFFF" CornerRadius="8" Padding="8" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding SimulateOverlapCommand}"
                        Content="{StaticResource SimulateOverlap}" Style="{StaticResource SimulationErrorButtonStyle}"
                        FontSize="9" FontWeight="Bold" Height="28" Padding="12,0" Margin="4,0"/>
                <Button Command="{Binding SimulateJamCommand}"
                        Content="{StaticResource SimulateJam}" Style="{StaticResource SimulationErrorButtonStyle}"
                        FontSize="9" FontWeight="Bold" Height="28" Padding="12,0" Margin="4,0"/>
                <Button Command="{Binding ResetErrorCommand}"
                        Content="{StaticResource Reset}"
                        FontSize="9" FontWeight="Bold" Height="28" Padding="12,0" Margin="4,0">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ErrorResetButtonStyle}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsJammed.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsOverlapped.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDeviceError.Value}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{StaticResource Cancel}" Click="CancelButton_Click" 
                    Style="{StaticResource SecondaryButtonStyle}" 
                    Margin="0,0,12,0" 
                    AutomationProperties.AutomationId="BulkCancelButton"
                    Width="100" Height="40"/>
            <Button x:Name="ConfirmButton" Content="{StaticResource Ok}" Click="OkButton_Click" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    AutomationProperties.AutomationId="BulkConfirmButton"
                    MinWidth="100" Height="40"/>
        </StackPanel>
    </Grid>
</Window>
