<Window x:Class="CashChangerSimulator.UI.Wpf.Views.BulkAmountInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        Title="BULK INPUT" Height="450" Width="380"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="BulkAmountInputWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.Foreground="{StaticResource OnBackgroundBrush}"
        ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock x:Name="TitleText" Text="BULK INPUT" 
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontWeight="Black"/>
            <TextBlock x:Name="SubtitleText" Text="金種ごとの数量を入力してください" FontSize="11" Opacity="0.4" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,16" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
                            <TextBox Grid.Column="1" Text="{Binding Quantity.Value, UpdateSourceTrigger=PropertyChanged}" 
                                     materialDesign:HintAssist.Hint="0"
                                     AutomationProperties.AutomationId="BulkQuantityBox"
                                     TextAlignment="Right"
                                     FontSize="14"
                                     Padding="4"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="CANCEL" Click="CancelButton_Click" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Margin="0,0,12,0" 
                    AutomationProperties.AutomationId="BulkCancelButton"
                    Width="100" Height="40"/>
            <Button x:Name="ConfirmButton" Content="OK" Click="OkButton_Click" 
                    Style="{StaticResource PrimaryButtonStyle}" 
                    AutomationProperties.AutomationId="BulkConfirmButton"
                    Width="auto" Height="40"/>
        </StackPanel>
    </Grid>
</Window>
