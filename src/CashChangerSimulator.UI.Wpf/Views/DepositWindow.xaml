<Window x:Class="CashChangerSimulator.UI.Wpf.Views.DepositWindow"
        x:ClassModifier="internal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        xmlns:views="clr-namespace:CashChangerSimulator.UI.Wpf.Views"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:DepositViewModel}"
        Title="{StaticResource DepositTerminal}" Height="650" Width="420"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="DepositWindow"
        Background="{DynamicResource MaterialDesign.Brush.Background}"
        Foreground="{DynamicResource MaterialDesign.Brush.OnBackground}"
        TextElement.Foreground="{DynamicResource MaterialDesign.Brush.OnBackground}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="16"
        ResizeMode="CanResize" MinWidth="360" MinHeight="500">

    <!-- Removed explicit dialog width and let dialog scale with its content. Margin and internal padded Grid manage padding -->
    <materialDesign:DialogHost Identifier="DepositDialog" Style="{StaticResource MaterialDesignEmbeddedDialogHost}">
        <Border Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="{StaticResource DepositTerminal}" 
                               Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                               Foreground="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}"
                               FontWeight="Black"/>
                    <!-- Window Marker for UI Automation -->
                    <Button AutomationProperties.AutomationId="DepositWindowMark" Opacity="0.01" Width="1" Height="1" IsHitTestVisible="False" Focusable="False" VerticalAlignment="Top" HorizontalAlignment="Left" />
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <views:DepositIdleView AutomationProperties.AutomationId="DepositIdleView">
                            <views:DepositIdleView.Style>
                                <Style TargetType="UserControl">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentState.Value}" Value="{x:Static vm:DepositUIState.Idle}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </views:DepositIdleView.Style>
                        </views:DepositIdleView>

                        <views:DepositActiveView AutomationProperties.AutomationId="DepositActiveView">
                            <views:DepositActiveView.Style>
                                <Style TargetType="UserControl">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentState.Value}" Value="{x:Static vm:DepositUIState.Active}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </views:DepositActiveView.Style>
                        </views:DepositActiveView>

                        <views:DepositErrorView AutomationProperties.AutomationId="DepositErrorView">
                            <views:DepositErrorView.Style>
                                <Style TargetType="UserControl">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentState.Value}" Value="{x:Static vm:DepositUIState.Error}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </views:DepositErrorView.Style>
                        </views:DepositErrorView>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </materialDesign:DialogHost>
</Window>
