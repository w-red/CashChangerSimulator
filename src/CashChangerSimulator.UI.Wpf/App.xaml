<Application x:Class="CashChangerSimulator.UI.Wpf.App"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CashChangerSimulator.UI.Wpf"
             xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                
                <!-- Application Themes -->
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Colors.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Strings.common.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Strings.en-US.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Templates.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <materialDesign:SnackbarMessageQueue x:Key="MainMessageQueue" />

            <conv:CashStatusToBrushConverter x:Key="StatusBrushConv" />
            <conv:TransactionTypeToSymbolConverter x:Key="TypeSymbolConv" />
            <conv:InvertedBooleanToVisibilityConverter x:Key="InvertedVisibilityConv" />
            <conv:InverseBooleanConverter x:Key="InverseBoolConverter" />
            <conv:DepositModeBackgroundConverter x:Key="DepositModeBackgroundConv" />
            <BooleanToVisibilityConverter x:Key="VisibilityConv" />
            <conv:UIModeToVisibilityConverter x:Key="UIModeVisibilityConv" />
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConv" />

        </ResourceDictionary>
    </Application.Resources>
</Application>
