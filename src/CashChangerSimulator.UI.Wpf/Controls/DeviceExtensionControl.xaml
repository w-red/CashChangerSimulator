<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.DeviceExtensionControl"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:DeviceExtensionViewModel}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}" Background="{DynamicResource MaterialDesign.Brush.Surface}">
        <StackPanel>
            <TextBlock Text="{StaticResource AdvancedSimulation}" FontSize="12" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" FontWeight="Black" Margin="0,0,0,16"/>
            
            <StackPanel Margin="0,0,0,16">
                <!-- Settings Toggle Section -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="{StaticResource RealTimeData}" VerticalAlignment="Center" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"/>
                    <ToggleButton Grid.Column="1" 
                                   IsChecked="{Binding IsRealTimeDataEnabled.Value}" 
                                   Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                   ToolTip="{StaticResource RealTimeData}" />
                </Grid>

                <Separator Background="{DynamicResource MaterialDesign.Brush.OnSurface}" Opacity="0.3" Margin="0,8"/>

                <!-- Scripts Section -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,12" Visibility="{Binding IsDepositInProgress.Value, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{StaticResource CurrentDeposit}" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CurrencyPrefix}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat='{}{0:N0}'}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding CurrencySuffix}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" Margin="4,0,0,0" />
                </StackPanel>

                <TextBlock Text="{StaticResource ScriptInput}" FontSize="13" FontWeight="Bold" Margin="0,8,0,8" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"/>
                <TextBox Text="{Binding ScriptInput.Value, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBoxStyle}" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
                         materialDesign:HintAssist.Hint="" materialDesign:HintAssist.IsFloating="False"
                         materialDesign:TextFieldAssist.PrefixText=""
                         AutomationProperties.Name="JSON Transaction Script Input"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="150" FontFamily="Consolas" Margin="0,0,0,8"/>
                
                <TextBlock Text="{Binding ScriptError.Value}" Foreground="{DynamicResource MaterialDesign.Brush.Error}" Visibility="{Binding ScriptError.Value, Converter={StaticResource StringNullOrEmptyToVisibilityConv}}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                
                <Button Style="{StaticResource PrimaryButtonStyle}" 
                        Content="{StaticResource Ok}" 
                        Command="{Binding ExecuteScriptCommand}" 
                        HorizontalAlignment="Right" Margin="0,8,0,0" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
