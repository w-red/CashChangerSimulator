<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.DeviceExtensionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:DeviceExtensionViewModel}">
    
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}" Background="{StaticResource SurfaceBrush}">
        <StackPanel>
            <TextBlock Text="ADVANCED SIMULATION" FontSize="12" Foreground="{StaticResource PrimaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
            
            <StackPanel Margin="0,0,0,16">
                <!-- Settings Toggle Section -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Enable Real Time Data Events" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <ToggleButton Grid.Column="1" 
                                   IsChecked="{Binding IsRealTimeDataEnabled.Value}" 
                                   Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                   ToolTip="Toggles the UPOS CapRealTimeData status to fire DataEvents for all deposit tracks" />
                </Grid>

                <Separator Background="{StaticResource TextPrimaryBrush}" Opacity="0.3" Margin="0,8"/>

                <!-- Scripts Section -->
                <StackPanel Orientation="Horizontal" Margin="0,12,0,12" Visibility="{Binding IsDepositInProgress.Value, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Current Deposit: " Foreground="{StaticResource TextPrimaryBrush}" FontWeight="Bold" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding CurrencySymbol}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                    <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat='{}{0:N0}'}" Foreground="{DynamicResource SecondaryBrush}" FontWeight="Black" FontSize="20" VerticalAlignment="Bottom" />
                </StackPanel>

                <TextBlock Text="JSON Transaction Script" FontSize="13" FontWeight="Bold" Margin="0,8,0,8" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBox Text="{Binding ScriptInput.Value, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBoxStyle}" Foreground="{StaticResource TextPrimaryBrush}"
                         materialDesign:HintAssist.Hint="" materialDesign:HintAssist.IsFloating="False"
                         materialDesign:TextFieldAssist.PrefixText=""
                         AutomationProperties.Name="JSON Transaction Script Input"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Height="150" FontFamily="Consolas" Margin="0,0,0,8"/>
                
                <TextBlock Text="{Binding ScriptError.Value}" Foreground="{StaticResource ErrorBrush}" Visibility="{Binding ScriptError.Value, Converter={StaticResource StringNullOrEmptyToVisibilityConv}}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8" TextWrapping="Wrap"/>
                
                <Button Style="{StaticResource PrimaryButtonStyle}" 
                        Content="Execute Script" 
                        Command="{Binding ExecuteScriptCommand}" 
                        HorizontalAlignment="Right" Margin="0,8,0,0" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
