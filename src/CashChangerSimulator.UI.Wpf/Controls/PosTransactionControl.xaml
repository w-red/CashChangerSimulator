<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.PosTransactionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:PosTransactionViewModel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Transaction Progress Area -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="{StaticResource TransactionStatus}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
                
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <TextBlock Text="{Binding StatusText.Value}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                        <TextBlock Text="{Binding Message.Value}" FontSize="14" Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <materialDesign:PackIcon Grid.Column="1" Kind="CashMultiple" Width="48" Height="48" Foreground="{StaticResource PrimaryBrush}" Opacity="0.2"/>
                </Grid>

                <ProgressBar Value="{Binding Progress.Value}" Height="4" Background="#15FFFFFF" Foreground="{StaticResource PrimaryBrush}"/>
                
                <Grid Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="Input: " FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrencyPrefix}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrentAmount.Value, StringFormat='{}{0:N0}'}" FontSize="12" FontWeight="Bold"/>
                        <TextBlock Text="{Binding CurrencySuffix}" FontSize="12" FontWeight="Bold" Margin="2,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="Target: " FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{Binding CurrencyPrefix}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{Binding TotalTargetAmount.Value, StringFormat='{}{0:N0}'}" FontSize="12" Opacity="0.6"/>
                        <TextBlock Text="{Binding CurrencySuffix}" FontSize="12" Opacity="0.6" Margin="2,0,0,0"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" MinWidth="300" />
            </Grid.ColumnDefinitions>

            <!-- Interaction Area -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,16,0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Idle State -->
                    <StackPanel Visibility="{Binding TransactionStatus.Value, Converter={StaticResource UIModeVisibilityConv}, ConverterParameter=Idle}">
                        <materialDesign:PackIcon Kind="CashRegister" Width="64" Height="64" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="{StaticResource ReadyForTransaction}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <TextBox Text="{Binding TargetAmountInput.Value, UpdateSourceTrigger=PropertyChanged}" 
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 materialDesign:HintAssist.Hint="Enter Target Amount"
                                 materialDesign:TextFieldAssist.PrefixText="{Binding CurrencyPrefix}"
                                 FontSize="24" FontWeight="Bold" Height="60" Margin="0,8,0,0"/>
                        <TextBlock Text="{Binding CurrencySuffix}" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,12,12" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Visibility="{Binding CurrencySuffix, Converter={StaticResource ingNullOrEmptyToVisibilityConv}}"/>
                        <Button Style="{StaticResource PrimaryButtonStyle}" 
                                Content="{StaticResource StartSimulation}" 
                                Command="{Binding StartCommand}"
                                Width="240" />
                    </StackPanel>

                    <!-- Waiting for Cash State -->
                    <StackPanel Visibility="{Binding TransactionStatus.Value, Converter={StaticResource UIModeVisibilityConv}, ConverterParameter=WaitingForCash}">
                        <TextBlock Text="{StaticResource InsertCashToContinue}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <ItemsControl ItemsSource="{Binding AvailableDenominations}"
                                      ItemsPanel="{StaticResource CenteredWrapPanelItemsPanel}"
                                      ItemTemplate="{StaticResource CashInsertionTemplate}">
                        </ItemsControl>
                    </StackPanel>

                    <!-- Completed State -->
                    <StackPanel Visibility="{Binding TransactionStatus.Value, Converter={StaticResource UIModeVisibilityConv}, ConverterParameter=Completed}">
                        <materialDesign:PackIcon Kind="CheckCircle" Width="64" Height="64" HorizontalAlignment="Center" Foreground="LightGreen" Margin="0,0,0,16"/>
                        <TextBlock Text="{StaticResource TransactionFinished}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,24"/>
                        <Button Style="{StaticResource ModernFlatButtonStyle}" 
                                Content="{StaticResource Reset}" 
                                Command="{Binding ResetCommand}"
                                HorizontalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- OPOS Events Log -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{StaticResource OposDeviceLog}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
                    <ListBox ItemsSource="{Binding OposLog}" 
                             Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource LogItemStyle}"
                             ItemTemplate="{StaticResource OposLogItemTemplate}"
                             AutomationProperties.AutomationId="OposLogListBox">
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
