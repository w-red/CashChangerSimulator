<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.InventoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CashChangerSimulator.UI.Wpf.Controls"
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel}"
             AutomationProperties.AutomationId="InventoryComponent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Templates.xaml" />
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="340" />
        </Grid.ColumnDefinitions>
        
        <!-- Inventory Grid Area (Left) -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="{Binding BillGridWidth.Value}" />
                    <ColumnDefinition Width="{Binding CoinGridWidth.Value}" />
                </Grid.ColumnDefinitions>
                
                <!-- Bills Area -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="{StaticResource Bills}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,8" />
                    <ItemsControl ItemsSource="{Binding BillDenominations}"
                                  ItemsPanel="{StaticResource DefaultWrapPanelItemsPanel}"
                                  ItemTemplate="{StaticResource InventoryTileTemplate}"
                                  Margin="0,0,0,16">
                    </ItemsControl>
                </StackPanel>

                <!-- Coins Area -->
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="{StaticResource Coins}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}" Margin="8,0,0,8" />
                    <ItemsControl ItemsSource="{Binding CoinDenominations}"
                                  ItemsPanel="{StaticResource DefaultWrapPanelItemsPanel}"
                                  ItemTemplate="{StaticResource InventoryTileTemplate}">
                    </ItemsControl>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!-- Status & History Sidebar (Right) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <!-- Status Indicators -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Border Background="OrangeRed" Style="{StaticResource BadgeStyle}"
                                Visibility="{Binding IsOverlapped.Value, Converter={StaticResource VisibilityConv}}">
                            <TextBlock Text="{StaticResource ValidationError}"/>
                        </Border>
                        <Border Background="{Binding OverallStatus.Value, Converter={StaticResource StatusBrushConv}}" Style="{StaticResource BadgeStyle}">
                            <TextBlock Text="{Binding OverallStatus.Value}"/>
                        </Border>
                        <Border Background="{Binding FullStatus.Value, Converter={StaticResource StatusBrushConv}}" Style="{StaticResource BadgeStyle}" Margin="0">
                            <TextBlock Text="{Binding FullStatus.Value}"/>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ToggleButton Style="{StaticResource ModernToggleButtonStyle}"
                                      IsChecked="{Binding IsJammed.Value}"
                                      ToolTip="Simulate Mechanical Jam"
                                      Margin="0,0,8,0">
                            <materialDesign:PackIcon Kind="CarBrakeAlert" />
                            <materialDesign:ToggleButtonAssist.OnContent>
                                <materialDesign:PackIcon Kind="CarBrakeAlert" />
                            </materialDesign:ToggleButtonAssist.OnContent>
                        </ToggleButton>

                        <Button Style="{StaticResource ModernActionButtonStyle}"
                                Command="{Binding OpenSettingsCommand}"
                                ToolTip="System Settings"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource PrimaryBrush}">
                            <materialDesign:PackIcon Kind="Settings" Foreground="{StaticResource PrimaryBrush}"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Bulk Operations -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16" Padding="16">
                <StackPanel>
                    <TextBlock Text="{StaticResource BulkOperations}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,12"/>
                    <UniformGrid Columns="2">
                        <Button Style="{StaticResource ModernActionButtonStyle}"
                                Command="{Binding ReplenishAllCommand}"
                                ToolTip="Replenish All (Set to Initial Counts)"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="{StaticResource SuccessBrush}"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="HandCoin" Foreground="{StaticResource SuccessBrush}" Margin="0,0,4,0"/>
                                <TextBlock Text="{StaticResource ActionFill}" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource ModernActionButtonStyle}"
                                Command="{Binding CollectAllCommand}"
                                ToolTip="Collect All (Set to Zero)"
                                Background="{StaticResource SurfaceBrush}"
                                BorderBrush="OrangeRed">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="DeleteSweep" Foreground="OrangeRed" Margin="0,0,4,0"/>
                                <TextBlock Text="{StaticResource ActionEmpty}" Foreground="OrangeRed" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Activity Feed -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="{StaticResource ActivityFeed}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="Black" Margin="0,0,0,16"/>
                    
                    <ListBox ItemsSource="{Binding RecentTransactions}" Background="Transparent" BorderThickness="0"
                             ItemContainerStyle="{StaticResource TransactionListStyle}"
                             ItemTemplate="{StaticResource TransactionItemTemplate}"
                             AutomationProperties.AutomationId="HistoryListBox">
                    </ListBox>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
