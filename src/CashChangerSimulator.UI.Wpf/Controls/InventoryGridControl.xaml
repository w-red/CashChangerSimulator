<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.InventoryGridControl"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel}"
             AutomationProperties.AutomationId="InventoryComponent">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Templates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    
    <Grid>
        <!-- テスト専用ボタン: 金種詳細ダイアログを確実に開くためのエントリポイント。本番 UI には表示されない。-->
        <Button AutomationProperties.AutomationId="ShowFirstDenominationDetailTestButton"
                Width="100" Height="100" Opacity="0.01" Background="Transparent"
                Command="{Binding OpenFirstBillDenominationDetailCommand}"
                Focusable="False"
                IsTabStop="False"
                Panel.ZIndex="999"
                HorizontalAlignment="Left" VerticalAlignment="Top" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,12,0">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}"/>
                        <Setter Property="Margin" Value="8,0,0,8"/>
                    </Style>
                </StackPanel.Resources>

                <!-- Bills Section -->
                <TextBlock Text="{StaticResource Bills}" />
                <ItemsControl ItemsSource="{Binding BillDenominations}"
                              ItemsPanel="{StaticResource DefaultWrapPanelItemsPanel}"
                              ItemTemplate="{StaticResource InventoryTileTemplate}"
                              Margin="0,0,0,16">
                </ItemsControl>

                <Separator Background="{DynamicResource MaterialDesign.Brush.Outline}" Margin="8,8,16,16" Opacity="0.5"/>

                <!-- Coins Section -->
                <TextBlock Text="{StaticResource Coins}" />
                <ItemsControl ItemsSource="{Binding CoinDenominations}"
                              ItemsPanel="{StaticResource DefaultWrapPanelItemsPanel}"
                              ItemTemplate="{StaticResource InventoryTileTemplate}"
                              Margin="0,0,0,8">
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
