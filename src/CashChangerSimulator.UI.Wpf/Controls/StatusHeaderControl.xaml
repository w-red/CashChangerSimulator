<UserControl x:Class="CashChangerSimulator.UI.Wpf.Controls.StatusHeaderControl"
             x:ClassModifier="internal"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance Type=vm:InventoryViewModel}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <StackPanel VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
            <Border Background="{DynamicResource App.Brush.Error}" Style="{StaticResource BadgeStyle}"
                    Visibility="{Binding IsConnected.Value, Converter={StaticResource InvertedVisibilityConv}}">
                <TextBlock Text="{StaticResource DeviceClosed}" />
            </Border>
            <Border Background="{DynamicResource App.Brush.Error}" Style="{StaticResource BadgeStyle}"
                    Visibility="{Binding IsDeviceError.Value, Converter={StaticResource VisibilityConv}}">
                <TextBlock>
                    <Run Text="{StaticResource ErrorDevicePrefix}" /><Run Text="{Binding CurrentErrorCode.Value, Mode=OneWay}" /><Run Text="{StaticResource ErrorDeviceSuffix}" />
                </TextBlock>
            </Border>
            <!-- Test Markers: Always in the UIA tree, but hidden from users -->
            <Label AutomationProperties.AutomationId="JamErrorIndicator_State" 
                   Visibility="Visible" Opacity="0" Width="1" Height="1"
                   IsEnabled="{Binding IsJammed.Value}"/>
            <Label AutomationProperties.AutomationId="OverlapErrorIndicator_State" 
                   Visibility="Visible" Opacity="0" Width="1" Height="1"
                   IsEnabled="{Binding IsOverlapped.Value}"/>

            <!-- Jam Error Indicator: Visible only when jammed -->
            <Border Background="{DynamicResource App.Brush.Jam}" 
                    Visibility="{Binding IsJammed.Value, Converter={StaticResource VisibilityConv}}"
                    Style="{StaticResource BadgeStyle}">
                <TextBlock Text="{StaticResource JamError}"/>
            </Border>
            <!-- Overlap Error Indicator: Visible only when overlapped -->
            <Border Background="{DynamicResource App.Brush.Overlap}" 
                    Visibility="{Binding IsOverlapped.Value, Converter={StaticResource VisibilityConv}}"
                    Style="{StaticResource BadgeStyle}">
                <TextBlock Text="{StaticResource ReadError}"/>
            </Border>
            <Border Background="{Binding OverallStatus.Value, Converter={StaticResource StatusBrushConv}}" Style="{StaticResource BadgeStyle}"
                    Visibility="{Binding IsConnected.Value, Converter={StaticResource VisibilityConv}}">
                <TextBlock Text="{Binding OverallStatus.Value}"/>
            </Border>
            <Border Background="{Binding FullStatus.Value, Converter={StaticResource StatusBrushConv}}" Style="{StaticResource BadgeStyle}" Margin="0"
                    Visibility="{Binding IsConnected.Value, Converter={StaticResource VisibilityConv}}">
                <TextBlock Text="{Binding FullStatus.Value}"/>
            </Border>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- Reset Error Button: always in automation tree (Opacity=0 when hidden) for FlaUI test compatibility -->
            <Button Command="{Binding ResetErrorCommand}"
                    AutomationProperties.AutomationId="GlobalResetErrorButton"
                    ToolTip="{StaticResource ToolTipResetHardwareError}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource HeaderIconButtonStyle}">
                        <Setter Property="Background" Value="#FF5252"/>
                        <Setter Property="BorderBrush" Value="#FF5252"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Margin" Value="0,0,8,0"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <materialDesign:PackIcon Kind="Refresh" Width="18" Height="18"/>
            </Button>

            <ToggleButton IsChecked="{Binding IsJammed.Value, Mode=OneWay}"
                          Command="{Binding SimulateJamCommand}"
                          AutomationProperties.AutomationId="SimulateJamButton"
                          ToolTip="{StaticResource ToolTipSimulateJam}"
                          Margin="0,0,8,0">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource HeaderIconToggleButtonStyle}">
                        <Style.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WarningBrush}" />
                                <Setter Property="Foreground" Value="Black" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
                <materialDesign:PackIcon Kind="CarBrakeAlert" />
                <materialDesign:ToggleButtonAssist.OnContent>
                    <materialDesign:PackIcon Kind="Alert" />
                </materialDesign:ToggleButtonAssist.OnContent>
            </ToggleButton>

            <Button Style="{StaticResource HeaderIconButtonStyle}"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="{StaticResource ToolTipSystemSettings}"
                    Background="{DynamicResource MaterialDesign.Brush.Surface}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Primary}">
                <materialDesign:PackIcon Kind="Settings" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
            </Button>
        </StackPanel>
    </StackPanel>
</UserControl>
