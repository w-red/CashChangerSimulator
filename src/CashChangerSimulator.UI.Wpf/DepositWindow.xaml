<Window x:Class="CashChangerSimulator.UI.Wpf.DepositWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:DepositViewModel}"
        Title="DEPOSIT TERMINAL" Height="650" Width="420"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="DepositWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        ResizeMode="CanResize" MinWidth="360" MinHeight="500">

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="DEPOSIT TERMINAL" 
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="Black"/>
                <TextBlock Text="入金ターミナル" FontSize="10" Opacity="0.4" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- VIEW: IDLE / QUICK DEPOSIT -->
                    <StackPanel Visibility="{Binding IsInDepositMode.Value, Converter={StaticResource InvertedVisibilityConv}}">
                        <Button Style="{StaticResource PrimaryButtonStyle}" 
                                Command="{Binding BeginDepositCommand}"
                                Width="260" Height="48"
                                HorizontalAlignment="Center" Margin="0,16"
                                AutomationProperties.AutomationId="BeginDepositButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="HandPointingRight" Margin="0,0,12,0" Width="24" Height="24"/>
                                <TextBlock Text="START DEPOSIT" VerticalAlignment="Center" FontSize="16"/>
                            </StackPanel>
                        </Button>

                        <Separator Background="#1AFFFFFF" Margin="0,24"/>

                        <!-- Quick Deposit Input -->
                        <TextBlock Text="QUICK DEPOSIT" FontSize="11" FontWeight="Bold" 
                                   HorizontalAlignment="Center" Opacity="0.5" Margin="0,0,0,12"/>
                        <Grid Width="260" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox materialDesign:HintAssist.Hint="Amount" 
                                     Text="{Binding QuickDepositAmountInput.Value, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBoxStyle}"
                                     FontSize="18"
                                     Margin="0,0,12,0">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding QuickDepositCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1" 
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding QuickDepositCommand}"
                                    Padding="12,0" Height="40"
                                    AutomationProperties.AutomationId="QuickDepositButton">
                                <materialDesign:PackIcon Kind="Flash" Width="20" Height="20"/>
                            </Button>
                        </Grid>
                        <TextBlock Text="Calculates denominations automatically" 
                                   FontSize="10" Opacity="0.4" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- VIEW: ACTIVE DEPOSIT -->
                    <StackPanel Visibility="{Binding IsInDepositMode.Value, Converter={StaticResource VisibilityConv}}">
                        
                        <!-- Current Amount Display -->
                        <Border Background="#0DFFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="CURRENT DEPOSIT" FontSize="10" FontWeight="Bold" 
                                           Opacity="0.5" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CurrentDepositAmount.Value, StringFormat=¥{0:N0}}"  
                                           FontSize="40" FontWeight="Thin" HorizontalAlignment="Center"
                                           AutomationProperties.AutomationId="CurrentDepositText"/>
                            </StackPanel>
                        </Border>


                        
                        <!-- Main Actions (Not Fixed) -->
                        <StackPanel Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource ModernFlatButtonStyle}" 
                                        Command="{Binding ShowBulkInsertCommand}"
                                        Margin="4" Height="40"
                                        IsEnabled="{Binding IsDepositPaused.Value, Converter={StaticResource InverseBoolConverter}}"
                                        AutomationProperties.AutomationId="BulkInsertButton">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PlaylistPlus" Margin="0,0,8,0" />
                                        <TextBlock Text="BULK" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Style="{StaticResource ModernFlatButtonStyle}" 
                                        Command="{Binding SimulateOverlapCommand}"
                                        Margin="4" Height="40" Foreground="Orange"
                                        AutomationProperties.AutomationId="SimulateOverlapButton">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="LayersTripleOutline" Margin="0,0,8,0" />
                                        <TextBlock Text="ERROR" FontSize="13"/>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Button Style="{StaticResource ModernFlatButtonStyle}" 
                                    Command="{Binding FixDepositCommand}"
                                    HorizontalAlignment="Stretch" Margin="4,8" Height="44"
                                    AutomationProperties.AutomationId="FixDepositButton">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Check" Margin="0,0,12,0" />
                                    <TextBlock Text="FINISH COUNTING" Foreground="{StaticResource PrimaryBrush}" FontWeight="Bold" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Pause/Resume/Store/Return -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Pause/Resume -->
                                <Grid Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource InvertedVisibilityConv}}">
                                    <Button Style="{StaticResource ModernFlatButtonStyle}" 
                                            Command="{Binding PauseDepositCommand}"
                                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource InvertedVisibilityConv}}"
                                            Margin="4" Height="40"
                                            AutomationProperties.AutomationId="PauseDepositButton">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Pause" Margin="0,0,8,0"/>
                                            <TextBlock Text="PAUSE"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource PrimaryButtonStyle}" 
                                            Command="{Binding ResumeDepositCommand}"
                                            Visibility="{Binding IsDepositPaused.Value, Converter={StaticResource VisibilityConv}}"
                                            Margin="4" Height="40"
                                            AutomationProperties.AutomationId="ResumeDepositButton">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Play" Margin="0,0,8,0"/>
                                            <TextBlock Text="RESUME"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Store (Fixed state) -->
                                <Button Style="{StaticResource PrimaryButtonStyle}" 
                                        Command="{Binding StoreDepositCommand}"
                                        Visibility="{Binding IsDepositFixed.Value, Converter={StaticResource VisibilityConv}}"
                                        Margin="4" Height="44" AutomationProperties.AutomationId="StoreDepositButton">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Wallet" Margin="0,0,8,0" />
                                        <TextBlock Text="STORE" FontSize="14"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource ModernFlatButtonStyle}" 
                                    Command="{Binding CancelDepositCommand}"
                                    Foreground="IndianRed"
                                    Margin="4" Height="40"
                                    AutomationProperties.AutomationId="RepayDepositButton">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Cancel" Margin="0,0,8,0" />
                                    <TextBlock Text="RETURN" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
