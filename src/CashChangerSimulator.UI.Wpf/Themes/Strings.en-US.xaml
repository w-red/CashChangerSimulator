<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Common Strings -->
    <system:String x:Key="StrCancel">CANCEL</system:String>
    <system:String x:Key="StrOk">OK</system:String>
    <system:String x:Key="StrError">ERROR</system:String>
    <system:String x:Key="StrReset">RESET</system:String>
    <system:String x:Key="StrBusy">BUSY</system:String>

    <system:String x:Key="StrCashBalance">CASH BALANCE</system:String>
    <system:String x:Key="StrActivityFeed">ACTIVITY FEED</system:String>
    <system:String x:Key="StrValidationError">VAL ERROR</system:String>

    <!-- Validation Messages -->
    <system:String x:Key="StrErrorEnterValidNumber">Enter a valid number</system:String>
    <system:String x:Key="StrErrorAmountPositive">Amount must be positive</system:String>
    <system:String x:Key="StrErrorInsufficientFunds">Insufficient funds</system:String>

    <!-- Main Window / Settings -->
    <system:String x:Key="StrSystemSettings">SYSTEM SETTINGS</system:String>
    <system:String x:Key="StrSettingsSubtitle">Configure device behavior and currency parameters</system:String>
    <system:String x:Key="StrCoreParameters">CORE PARAMETERS</system:String>
    <system:String x:Key="StrRestartRequired">* Requires restart for inventory recalibration.</system:String>
    <system:String x:Key="StrUIBehaviorNote">* Change the user interface behavior pattern.</system:String>
    <system:String x:Key="StrGlobalThresholds">GLOBAL THRESHOLDS</system:String>
    <system:String x:Key="StrDenomCalibration">DENOMINATION CALIBRATION</system:String>

    <!-- Simulation Page -->
    <system:String x:Key="StrTerminalAccess">TERMINAL ACCESS</system:String>
    <system:String x:Key="StrDeposit">DEPOSIT</system:String>
    <system:String x:Key="StrDispense">DISPENSE</system:String>
    <system:String x:Key="StrTransactionStatus">TRANSACTION STATUS</system:String>
    <system:String x:Key="StrOposDeviceLog">OPOS DEVICE LOG</system:String>
    <system:String x:Key="StrStartSimulation">START SIMULATION</system:String>
    <system:String x:Key="StrReadyForTransaction">Ready for Transaction</system:String>
    <system:String x:Key="StrInsertCashToContinue">Insert Cash to Continue</system:String>
    <system:String x:Key="StrTransactionFinished">Transaction Finished</system:String>

    <!-- Terminals -->
    <system:String x:Key="StrDispenseTerminal">DISPENSE TERMINAL</system:String>
    <system:String x:Key="StrDepositTerminal">DEPOSIT TERMINAL</system:String>
    <system:String x:Key="StrAmountDispense">AMOUNT DISPENSE</system:String>
    <system:String x:Key="StrBulkDispense">BULK DISPENSE</system:String>
    <system:String x:Key="StrDispenseError">DISPENSE ERROR</system:String>
    <system:String x:Key="StrHardwareCheckRequired">Hardware check required.</system:String>
    <system:String x:Key="StrClearError">CLEAR ERROR</system:String>
    <system:String x:Key="StrDispensing">DISPENSING...</system:String>

    <system:String x:Key="StrCurrentDeposit">CURRENT DEPOSIT</system:String>
    <system:String x:Key="StrStartDeposit">START DEPOSIT</system:String>
    <system:String x:Key="StrQuickDeposit">QUICK DEPOSIT</system:String>
    <system:String x:Key="StrAutoCalcDenoms">Calculates denominations automatically</system:String>
    <system:String x:Key="StrBulk">BULK</system:String>
    <system:String x:Key="StrFinishCounting">FINISH COUNTING</system:String>
    <system:String x:Key="StrPause">PAUSE</system:String>
    <system:String x:Key="StrResume">RESUME</system:String>
    <system:String x:Key="StrStore">STORE</system:String>
    <system:String x:Key="StrReturn">RETURN</system:String>

    <!-- Footer Actions -->
    <system:String x:Key="StrCommitChanges">COMMIT CHANGES</system:String>
    <system:String x:Key="StrDefault">DEFAULT</system:String>

    <!-- Table Headers -->
    <system:String x:Key="StrHeaderIdentifier">IDENTIFIER</system:String>
    <system:String x:Key="StrHeaderBaseQty">BASE QTY</system:String>
    <system:String x:Key="StrHeaderNearEmpty">N.EMPTY</system:String>
    <system:String x:Key="StrHeaderNearFull">N.FULL</system:String>
    <system:String x:Key="StrHeaderMaxCap">MAX CAP</system:String>

    <!-- Bulk Input Dialog -->
    <system:String x:Key="StrBulkInput">BULK INPUT</system:String>
    <system:String x:Key="StrBulkInputDefaultSubtitle">Please enter the quantity for each denomination.</system:String>
    <system:String x:Key="StrBulkDepositSubtitle">Please enter the quantity to deposit.</system:String>
    <system:String x:Key="StrBulkDispenseSubtitle">Please enter the quantity to dispense.</system:String>

</ResourceDictionary>
