<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Light Theme Palette -->
    <Color x:Key="PrimaryColor">#6200EE</Color>
    <Color x:Key="SecondaryColor">#03DAC6</Color>
    <Color x:Key="BackgroundColor">#F5F5F5</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="OnSurfaceColor">#000000</Color>
    <Color x:Key="OnSurfaceVariantColor">#444444</Color>
    <Color x:Key="OutlineColor">#888888</Color>
    <Color x:Key="SurfaceVariantColor">#E0E0E0</Color>
    <Color x:Key="SurfaceContainerHighColor">#F0F0F0</Color>
    <Color x:Key="InventoryTileBackgroundColor">#FFFFFF</Color> <!-- Tiles are white on light gray container -->
    <Color x:Key="WarningColor">#FF8C00</Color>
    <Color x:Key="WarningForegroundColor">#000000</Color>

    <SolidColorBrush x:Key="App.Brush.Close.Background" Color="#E0E0E0" />
    <SolidColorBrush x:Key="App.Brush.Close.Foreground" Color="Black" />
</ResourceDictionary>
