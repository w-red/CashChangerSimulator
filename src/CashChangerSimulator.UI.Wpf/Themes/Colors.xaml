<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Cash Changer Simulator - Soft Dark Design System
      Primary: BB86FC (Vibrant Light Purple)
      Background: #0D0D0D (Soft Charcoal Black)
      Surface: #161616 (Soft Card Black)
    -->

    <Color x:Key="BackgroundColor">#0D0D0D</Color>
    <Color x:Key="SurfaceColor">#161616</Color>
    <Color x:Key="PrimaryColor">#BB86FC</Color>
    <Color x:Key="OnBackgroundColor">#E0E0E0</Color>
    <Color x:Key="OnSurfaceColor">#E0E0E0</Color>

    <!--
      Standard MaterialDesign Brushes should NOT be overridden with static values here.
      They are managed dynamically by PaletteHelper in App.xaml.cs.
    -->
</ResourceDictionary>
