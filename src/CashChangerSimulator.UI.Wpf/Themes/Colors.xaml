<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
      Cash Changer Simulator - Design System Colors
      These colors are theme-independent shared resources.
      Theme-specific colors are defined in Colors.Light.xaml and Colors.Dark.xaml.
    -->

    <!-- Shared Brushes for Alerts and Errors -->
    <SolidColorBrush x:Key="App.Brush.Error" Color="#D32F2F" />
    <SolidColorBrush x:Key="App.Brush.Jam" Color="#FF5252" />
    <SolidColorBrush x:Key="App.Brush.Overlap" Color="OrangeRed" />
    <SolidColorBrush x:Key="App.Brush.Warning" Color="Goldenrod" />
    <SolidColorBrush x:Key="App.Brush.Reject" Color="OrangeRed" />
    <SolidColorBrush x:Key="App.Brush.AccentError" Color="IndianRed" />

    <!--
      Standard MaterialDesign Brushes are managed dynamically by PaletteHelper in App.xaml.cs.
    -->
</ResourceDictionary>
