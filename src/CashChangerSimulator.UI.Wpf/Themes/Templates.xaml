<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
                    xmlns:views="clr-namespace:CashChangerSimulator.UI.Wpf.Views"
                    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:IntToStringConverter x:Key="IntToStrConv" />

    <!-- ItemsPanel Templates -->
    <ItemsPanelTemplate x:Key="CenteredWrapPanelItemsPanel">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="DefaultWrapPanelItemsPanel">
        <UniformGrid Columns="3" />
    </ItemsPanelTemplate>

    <!-- Inventory Tile Template -->
    <DataTemplate x:Key="InventoryTileTemplate" DataType="{x:Type vm:DenominationViewModel}">
        <Button Command="{Binding ShowDetailCommand}"
                CommandParameter="{Binding}"
                Style="{StaticResource MaterialDesignFlatButton}"
                Padding="0" Background="Transparent" BorderBrush="Transparent"
                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                AutomationProperties.AutomationId="InventoryTile"
                Cursor="Hand"
                Margin="0,0,8,8" Width="180" Height="140">
            <Border x:Name="TileBorder" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" BorderThickness="2" BorderBrush="Transparent" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Color="{DynamicResource MaterialDesign.Color.Primary}" Opacity="0" ShadowDepth="0" />
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAcceptingCash.Value}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="{DynamicResource MaterialDesign.Color.Primary}" Duration="0:0:0.5" RepeatBehavior="Forever" AutoReverse="True" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                            To="0.6" Duration="0:0:0.5" RepeatBehavior="Forever" AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="Transparent" Duration="0:0:0.2" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                            To="0" Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            
                            <!-- Hover Effect -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.05" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.05" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="8,8,8,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="{Binding Name}" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}" FontSize="14" FontWeight="Bold" 
                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" Margin="0,0,0,2"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Border Background="{DynamicResource MaterialDesign.Brush.Secondary}" CornerRadius="2" Padding="4,1" Margin="0,0,4,0"
                                    Visibility="{Binding IsRecyclable, Converter={StaticResource InvertedVisibilityConv}}">
                                <TextBlock Text="{StaticResource BadgeCollection}" Foreground="{DynamicResource MaterialDesign.Brush.OnSecondary}" FontSize="10" FontWeight="Black"/>
                            </Border>
                            <TextBlock Text="{Binding Status.Value}" Foreground="{Binding Status.Value, Converter={StaticResource StatusBrushConv}}" FontSize="11" FontWeight="Black"/>
                        </StackPanel>
                    </Grid>
                    
                    <Grid Grid.Row="1" Margin="4">
                        <TextBlock Text="{Binding Count.Value}" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                   FontSize="28" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Button>
    </DataTemplate>

    <!-- Cash Insertion Template -->
    <DataTemplate x:Key="CashInsertionTemplate">
        <Button Style="{StaticResource ModernFlatButtonStyle}"
                Content="{Binding Name}"
                Command="{Binding DataContext.InsertCashCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"
                Margin="4" Width="80"/>
    </DataTemplate>

    <!-- Transaction Item Template (Activity Feed) -->
    <DataTemplate x:Key="TransactionItemTemplate">
        <Grid x:Name="RootGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <materialDesign:PackIcon Kind="{Binding Type, Converter={StaticResource TypeSymbolConv}}" 
                                     Foreground="{DynamicResource MaterialDesign.Brush.Primary}" 
                                     Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Type}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"/>
                <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="11" Opacity="0.6" Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"/>
            </StackPanel>
            
            <StackPanel x:Name="AmountContainer" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding DataContext.CurrencyPrefix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <TextBlock Text="{Binding DataContext.CurrencySuffix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{DynamicResource MaterialDesign.Brush.Primary}" Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding Amount}" Value="0">
                <Setter TargetName="AmountContainer" Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- OPOS Log Item Template -->
    <DataTemplate x:Key="OposLogItemTemplate">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" FontSize="10" Opacity="0.5" Width="75" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"/>
        </Grid>
    </DataTemplate>

    <!-- Bulk Input Item Template -->
    <DataTemplate x:Key="BulkInputItemTemplate">
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Grid.Column="1" Text="{Binding Quantity.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToStrConv}}" 
                     materialDesign:HintAssist.Hint="0"
                     AutomationProperties.AutomationId="BulkQuantityBox"
                     TextAlignment="Right"
                     FontSize="14"
                     Padding="4"/>
        </Grid>
    </DataTemplate>

    <!-- View Switching Templates -->
    <DataTemplate x:Key="DispenseIdleTemplate"><views:DispenseIdleView /></DataTemplate>
    <DataTemplate x:Key="DispenseBusyTemplate"><views:DispenseBusyView /></DataTemplate>
    <DataTemplate x:Key="DispenseErrorTemplate">
        <views:DispenseErrorView />
    </DataTemplate>

    <DataTemplate x:Key="DepositErrorTemplate">
        <Grid>
            <!-- DepositErrorView does not exist yet. Only showing reset button for now if ever used. -->
            <Button Content="{StaticResource ResetError}"
                    Command="{Binding ResetErrorCommand}"
                    Style="{StaticResource ErrorResetButtonStyle}"
                    Margin="0,0,0,20" Padding="30,10" FontSize="18" FontWeight="Bold"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DepositIdleTemplate"><views:DepositIdleView /></DataTemplate>
    <DataTemplate x:Key="DepositActiveTemplate"><views:DepositActiveView /></DataTemplate>

</ResourceDictionary>
