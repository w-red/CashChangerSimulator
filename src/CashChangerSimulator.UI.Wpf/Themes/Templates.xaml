<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
                    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
                    xmlns:views="clr-namespace:CashChangerSimulator.UI.Wpf.Views"
                    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Colors.xaml" />
        <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:IntToStringConverter x:Key="IntToStrConv" />

    <!-- ItemsPanel Templates -->
    <ItemsPanelTemplate x:Key="CenteredWrapPanelItemsPanel">
        <WrapPanel HorizontalAlignment="Center" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="DefaultWrapPanelItemsPanel">
        <WrapPanel />
    </ItemsPanelTemplate>

    <!-- Inventory Tile Template -->
    <DataTemplate x:Key="InventoryTileTemplate" DataType="{x:Type vm:DenominationViewModel}">
        <Border MinWidth="170" MinHeight="185" Margin="0,0,16,16" Padding="4" ClipToBounds="True" RenderTransformOrigin="0.5,0.5" BorderThickness="2" BorderBrush="Transparent">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="{StaticResource PrimaryColor}" Opacity="0" ShadowDepth="0" />
            </Border.Effect>
            <Border.RenderTransform>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Border.RenderTransform>
            <Border.Style>
                <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAcceptingCash.Value}" Value="True">
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="{StaticResource PrimaryColor}" Duration="0:0:0.5" RepeatBehavior="Forever" AutoReverse="True" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                        To="0.6" Duration="0:0:0.5" RepeatBehavior="Forever" AutoReverse="True" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                            <DataTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                        To="Transparent" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                        To="0" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.ExitActions>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="16,16,16,0">
                    <Grid>
                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding Status.Value}" Foreground="{Binding Status.Value, Converter={StaticResource StatusBrushConv}}" FontSize="10" FontWeight="Black" HorizontalAlignment="Right" VerticalAlignment="Top"/>
                    </Grid>
                    <ProgressBar Value="{Binding Count.Value}" Minimum="0" Maximum="200" Height="8" 
                                Foreground="{Binding Status.Value, Converter={StaticResource StatusBrushConv}}" Background="#15FFFFFF" BorderThickness="0"
                                materialDesign:TransitionAssist.DisableTransitions="False"/>
                </StackPanel>
                
                <Viewbox Grid.Row="1" Stretch="Uniform" Margin="16" MaxHeight="80">
                    <TextBlock Text="{Binding Count.Value}" FontSize="54" FontWeight="Bold" 
                            Foreground="{StaticResource TextPrimaryBrush}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Viewbox>
            </Grid>
        </Border>
    </DataTemplate>

    <!-- Cash Insertion Template -->
    <DataTemplate x:Key="CashInsertionTemplate">
        <Button Style="{StaticResource ModernFlatButtonStyle}"
                Content="{Binding Name}"
                Command="{Binding DataContext.InsertCashCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"
                Margin="4" Width="80"/>
    </DataTemplate>

    <!-- Transaction Item Template (Activity Feed) -->
    <DataTemplate x:Key="TransactionItemTemplate">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <materialDesign:PackIcon Kind="{Binding Type, Converter={StaticResource TypeSymbolConv}}" 
                                     Foreground="{StaticResource PrimaryBrush}" 
                                     Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,16,0"/>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Type}" FontSize="13" FontWeight="Bold"/>
                <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss}" FontSize="11" Opacity="0.6"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding DataContext.CurrencyPrefix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,4,0"/>
                <TextBlock Text="{Binding Amount, StringFormat={}{0:N0}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryBrush}"/>
                <TextBlock Text="{Binding DataContext.CurrencySuffix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                           FontWeight="Bold" FontSize="15" Foreground="{StaticResource PrimaryBrush}" Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>
    </DataTemplate>

    <!-- OPOS Log Item Template -->
    <DataTemplate x:Key="OposLogItemTemplate">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" FontSize="10" Opacity="0.5" Width="75" VerticalAlignment="Top"/>
            <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="11" TextWrapping="Wrap" FontFamily="Consolas"/>
        </Grid>
    </DataTemplate>

    <!-- Bulk Input Item Template -->
    <DataTemplate x:Key="BulkInputItemTemplate">
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Grid.Column="1" Text="{Binding Quantity.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToStrConv}}" 
                     materialDesign:HintAssist.Hint="0"
                     AutomationProperties.AutomationId="BulkQuantityBox"
                     TextAlignment="Right"
                     FontSize="14"
                     Padding="4"/>
        </Grid>
    </DataTemplate>

    <!-- View Switching Templates -->
    <DataTemplate x:Key="DispenseIdleTemplate"><views:DispenseIdleView /></DataTemplate>
    <DataTemplate x:Key="DispenseBusyTemplate"><views:DispenseBusyView /></DataTemplate>
    <DataTemplate x:Key="DispenseErrorTemplate">
        <Grid>
            <views:DispenseErrorView />
            <Button Content="{StaticResource ResetErrorName}"
                    Command="{Binding ResetErrorCommand}"
                    Background="#FF5252" BorderBrush="Transparent" Foreground="White"
                    Margin="0,0,0,20" Padding="30,10" FontSize="18" FontWeight="Bold"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DepositErrorTemplate">
        <Grid>
            <!-- DepositErrorView does not exist yet. Only showing reset button for now if ever used. -->
            <Button Content="{StaticResource ResetErrorName}"
                    Command="{Binding ResetErrorCommand}"
                    Background="#FF5252" BorderBrush="Transparent" Foreground="White"
                    Margin="0,0,0,20" Padding="30,10" FontSize="18" FontWeight="Bold"
                    VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DepositIdleTemplate"><views:DepositIdleView /></DataTemplate>
    <DataTemplate x:Key="DepositActiveTemplate"><views:DepositActiveView /></DataTemplate>

</ResourceDictionary>
