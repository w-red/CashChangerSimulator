<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
    xmlns:views="clr-namespace:CashChangerSimulator.UI.Wpf.Views"
    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary
            Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Colors.xaml" />
        <ResourceDictionary
            Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Styles.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:IntToStringConverter x:Key="IntToStrConv" />

    <!-- ItemsPanel Templates -->
    <ItemsPanelTemplate
        x:Key="CenteredWrapPanelItemsPanel">
        <WrapPanel
            Orientation="Horizontal"
            HorizontalAlignment="Center" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate
        x:Key="DefaultWrapPanelItemsPanel">
        <WrapPanel
            Orientation="Horizontal" />
    </ItemsPanelTemplate>

    <!-- Inventory Tile Template -->
    <DataTemplate x:Key="InventoryTileTemplate" DataType="{x:Type vm:DenominationViewModel}">
        <Button
            Command="{Binding ShowDetailCommand}"
            CommandParameter="{Binding}"
            Style="{StaticResource MaterialDesignFlatButton}"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            HorizontalContentAlignment="Stretch"
            VerticalContentAlignment="Stretch"
            AutomationProperties.AutomationId="InventoryTile"
            Cursor="Hand"
            Margin="0,0,6,6"
            Width="140" Height="95">
            <Border
                x:Name="TileBorder"
                ClipToBounds="True"
                RenderTransformOrigin="0.5,0.5"
                BorderThickness="2"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Outline}"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="10"
                        Color="{StaticResource PrimaryColor}"
                        Opacity="0"
                        ShadowDepth="0" />
                </Border.Effect>
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border"
                           BasedOn="{StaticResource CardStyle}">
                        <Setter Property="Padding" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger
                                Binding="{Binding IsAcceptingCash.Value}"
                                Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="{StaticResource PrimaryColor}"
                                                Duration="0:0:0.5"
                                                RepeatBehavior="Forever"
                                                AutoReverse="True" />
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                To="0.6"
                                                Duration="0:0:0.5"
                                                RepeatBehavior="Forever"
                                                AutoReverse="True" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation
                                                Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                To="Transparent"
                                                Duration="0:0:0.2" />
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                                To="0"
                                                Duration="0:0:0.2" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                            </DataTrigger>
                            
                            <!-- Hover Effect -->
                            <Trigger
                                Property="IsMouseOver"
                                Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1.05"
                                                Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase
                                                        EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1.05"
                                                Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase
                                                        EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                To="1"
                                                Duration="0:0:0.2"/>
                                            <DoubleAnimation
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                To="1"
                                                Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="8,6,8,0">
                        <TextBlock
                            Text="{Binding Name}"
                            Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
                            FontSize="12"
                            FontWeight="Bold"
                            TextTrimming="CharacterEllipsis"
                            VerticalAlignment="Top"/>
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,2,0,0">
                            <Border
                                Background="{DynamicResource WarningBrush}"
                                Visibility="{Binding IsRecyclable, Converter={StaticResource InvertedVisibilityConv}}"
                                CornerRadius="2"
                                Padding="4,1"
                                Margin="0,0,4,0">
                                <TextBlock
                                    Text="{StaticResource BadgeCollection}"
                                    Foreground="Black"
                                    FontSize="9"
                                    FontWeight="Black" />
                            </Border>
                            <TextBlock
                                Text="{Binding Status.Value}"
                                Foreground="{Binding Status.Value, Converter={StaticResource StatusBrushConv}}"
                                FontSize="10"
                                FontWeight="Black"
                                VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <Grid Grid.Row="1"
                          Margin="4,0,4,4">
                        <Viewbox
                            Stretch="Uniform"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                            <TextBlock
                                Text="{Binding Count.Value}"
                                Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
                                FontSize="48"
                                FontWeight="Black"/>
                        </Viewbox>

                        <!-- Escrow Badge -->
                        <Border Background="{DynamicResource MaterialDesign.Brush.Primary}"
                                Visibility="{Binding HasEscrow.Value, Converter={StaticResource VisibilityConv}}"
                                CornerRadius="4"
                                Padding="4,2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Bottom"
                                Margin="0,0,2,2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{StaticResource SymbolHistory}" FontSize="10" Foreground="{DynamicResource MaterialDesign.Brush.OnPrimary}" Margin="0,0,4,0"/>
                                <TextBlock Text="{Binding EscrowCount.Value}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.OnPrimary}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Button>
    </DataTemplate>

    <!-- Cash Insertion Template -->
    <DataTemplate x:Key="CashInsertionTemplate">
        <Button Style="{StaticResource ModernFlatButtonStyle}"
                Content="{Binding Name}"
                Command="{Binding DataContext.InsertCashCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding}"
                Margin="4" Width="80"/>
    </DataTemplate>

    <!-- Escrow Item Template (Breakdown) -->
    <DataTemplate x:Key="EscrowItemTemplate">
        <Border BorderThickness="0,0,0,1" BorderBrush="{DynamicResource MaterialDesign.Brush.Outline}" Padding="0,8">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left" Text="{Binding Name}" FontWeight="Bold" Width="80"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding Count.Value, StringFormat={}{0:N0}}" TextAlignment="Right" Width="60"/>
                <TextBlock Text="{Binding Value, StringFormat={}{0:C0}}" Foreground="Gray" TextAlignment="Right"/>
            </DockPanel>
        </Border>
    </DataTemplate>

    <!-- Transaction Item Template (Activity Feed) -->
    <DataTemplate x:Key="TransactionItemTemplate">
        <Grid x:Name="RootGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <materialDesign:PackIcon
                x:Name="TypeIcon"
                Kind="{Binding Type, Converter={StaticResource TypeSymbolConv}}"
                Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                Width="20" Height="20"
                VerticalAlignment="Center"
                Margin="0,0,16,0"/>
            
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center">
                <TextBlock
                    Text="{Binding Type}"
                    FontSize="13"
                    FontWeight="Bold"
                    Foreground="{DynamicResource MaterialDesign.Brush.OnSurface}"
                    />
                <TextBlock
                    Text="{Binding Timestamp, StringFormat=HH:mm:ss}"
                    FontSize="11"
                    Foreground="{DynamicResource MaterialDesign.Brush.OnSurfaceVariant}"
                    />
            </StackPanel>
            
            <StackPanel
                x:Name="AmountContainer"
                Grid.Column="2"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <TextBlock
                    Text="{Binding DataContext.CurrencyPrefix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                    FontWeight="Bold"
                    FontSize="15"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    Margin="0,0,4,0"/>
                <TextBlock
                    Text="{Binding Amount, StringFormat={}{0:N0}}"
                    FontWeight="Bold"
                    FontSize="15"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    />
                <TextBlock
                    Text="{Binding DataContext.CurrencySuffix, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}" 
                    FontWeight="Bold"
                    FontSize="15"
                    Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                    Margin="4,0,0,0"/>
            </StackPanel>
        </Grid>
        <DataTemplate.Triggers>
            <DataTrigger
                Binding="{Binding Amount}" Value="0">
                <Setter TargetName="AmountContainer"
                        Property="Visibility"
                        Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger
                Binding="{Binding Type}" Value="HardwareError">
                <Setter TargetName="RootGrid"
                        Property="Opacity"
                        Value="1"/>
                <Setter TargetName="TypeIcon"
                        Property="Kind"
                        Value="AlertCircleOutline"/>
                <Setter TargetName="TypeIcon"
                        Property="Foreground"
                        Value="{DynamicResource WarningBrush}"/>
            </DataTrigger>
            <DataTrigger
                Binding="{Binding Type}"
                Value="ErrorRecovery">
                <Setter
                    TargetName="AmountContainer"
                    Property="Visibility"
                    Value="Collapsed"/>
                <Setter
                    TargetName="TypeIcon"
                    Property="Kind"
                    Value="WrenchOutline"/>
                <Setter
                    TargetName="TypeIcon"
                    Property="Foreground"
                    Value="{DynamicResource MaterialDesign.Brush.Success}" />
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <!-- OPOS Log Item Template -->
    <DataTemplate x:Key="OposLogItemTemplate">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="{Binding Timestamp, StringFormat=HH:mm:ss.fff}"
                FontSize="10"
                Opacity="0.5"
                Width="75"
                VerticalAlignment="Top"/>
            <TextBlock
                Grid.Column="1"
                Text="{Binding Message}"
                FontSize="11"
                TextWrapping="Wrap"
                FontFamily="Consolas"/>
        </Grid>
    </DataTemplate>

    <!-- Bulk Input Item Template -->
    <DataTemplate x:Key="BulkInputItemTemplate">
        <Grid Margin="0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock
                Text="{Binding Name}"
                VerticalAlignment="Center"
                FontSize="14"/>
            <TextBox
                Grid.Column="1"
                Text="{Binding Quantity.Value, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntToStrConv}}"
                materialDesign:HintAssist.Hint="0"
                AutomationProperties.AutomationId="BulkQuantityBox"
                TextAlignment="Right"
                FontSize="14"
                Padding="4"/>
        </Grid>
    </DataTemplate>

    <!-- View Switching Templates -->
    <DataTemplate x:Key="DispenseIdleTemplate">
        <views:DispenseIdleView />
    </DataTemplate>
    <DataTemplate x:Key="DispenseBusyTemplate">
        <views:DispenseBusyView />
    </DataTemplate>
    <DataTemplate x:Key="DispenseErrorTemplate">
        <views:DispenseErrorView />
    </DataTemplate>

    <DataTemplate x:Key="DepositErrorTemplate">
        <Grid>
            <!-- DepositErrorView does not exist yet. Only showing reset button for now if ever used. -->
            <Border
                Style="{StaticResource CardStyle}"
                Background="{DynamicResource MaterialDesign.Brush.SurfaceVariant}"
                Margin="0,0,0,16"
                Padding="12">
                <Button
                    Content="{StaticResource ResetError}"
                    Command="{Binding ResetErrorCommand}"
                    Style="{StaticResource ErrorResetButtonStyle}"
                    Padding="30,10"
                    FontSize="18"
                    FontWeight="Bold"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </DataTemplate>

    <DataTemplate x:Key="DepositIdleTemplate">
        <views:DepositIdleView />
    </DataTemplate>
    <DataTemplate x:Key="DepositActiveTemplate">
        <views:DepositActiveView />
    </DataTemplate>

</ResourceDictionary>
