<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Palette ("Soft Dark") -->
    <Color x:Key="PrimaryColor">#BB86FC</Color>
    <Color x:Key="SecondaryColor">#03DAC6</Color>
    <Color x:Key="BackgroundColor">#121212</Color>
    <Color x:Key="SurfaceColor">#343434</Color> <!-- [REFINE] Slightly lighter black for buttons/cards per user request -->
    <Color x:Key="OnSurfaceColor">#E0E0E0</Color>
    <Color x:Key="OnSurfaceVariantColor">#A0A0A0</Color>
    <Color x:Key="OutlineColor">#444444</Color>
    <Color x:Key="SurfaceVariantColor">#2C2C2C</Color>
    <Color x:Key="SurfaceContainerHighColor">#3D3D3D</Color>
    <Color x:Key="InventoryTileBackgroundColor">#1A1A1A</Color> <!-- Even darker for better contrast per user request -->
    <Color x:Key="WarningColor">#FFAB40</Color>
    <Color x:Key="WarningForegroundColor">#FFFFFF</Color> <!-- [REFINE] White for badge consistency -->

    <SolidColorBrush x:Key="App.Brush.Close.Background" Color="#333333" />
    <SolidColorBrush x:Key="App.Brush.Close.Foreground" Color="White" />
</ResourceDictionary>
