<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Palette ("Soft Dark") -->
    <Color x:Key="PrimaryColor">#BB86FC</Color>
    <Color x:Key="SecondaryColor">#03DAC6</Color>
    <Color x:Key="BackgroundColor">#121212</Color>
    <Color x:Key="SurfaceColor">#2A2A2A</Color> <!-- [REFINE] Darker for better immersion / より没入感のある暗さ -->
    <Color x:Key="OnSurfaceColor">#E0E0E0</Color>
    <Color x:Key="OnSurfaceVariantColor">#A0A0A0</Color>
    <Color x:Key="OutlineColor">#404040</Color>
    <Color x:Key="SurfaceVariantColor">#1F1F1F</Color> <!-- [REFINE] Darker variant / より暗いバリアント -->
    <Color x:Key="SurfaceContainerHighColor">#252525</Color> <!-- [REFINE] Reducer brightness for cards / カードの明るさを抑制 -->
    <Color x:Key="InventoryTileBackgroundColor">#121212</Color> <!-- Even darker for better contrast / コントラスト向上のためさらに暗く -->
    <Color x:Key="WarningColor">#FFAB40</Color>
    <Color x:Key="WarningForegroundColor">#FFFFFF</Color> <!-- [REFINE] White for badge consistency -->

    <SolidColorBrush x:Key="App.Brush.Close.Background" Color="#333333" />
    <SolidColorBrush x:Key="App.Brush.Close.Foreground" Color="White" />
</ResourceDictionary>
