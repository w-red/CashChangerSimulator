<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:CashChangerSimulator.UI.Wpf.Converters"
                    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/CashChangerSimulator.UI.Wpf;component/Themes/Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <conv:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConv" />

    <!-- Shared Styles (Optimized for Contrast) -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.SurfaceContainerHigh}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Outline}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Opacity="{DynamicResource CardShadowOpacity}" BlurRadius="4" ShadowDepth="0.5"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="20" ShadowDepth="3"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                <Setter Property="BorderThickness" Value="2"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="Button" x:Key="PrimaryButtonStyle" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.OnPrimary}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="24,8"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ModernFlatButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="#E53935"/>
        <Setter Property="BorderBrush" Value="#E53935"/>
        <Setter Property="Foreground" Value="White"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#D32F2F"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernFlatButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Container}"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.OnPrimary.Container}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="BorderThickness" Value="1.5"/>
        <Setter Property="materialDesign:RippleAssist.Feedback" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Container.Hover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SimulationErrorButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource WarningForegroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource WarningBrush}"/>
        <Setter Property="materialDesign:RippleAssist.Feedback" Value="{DynamicResource MaterialDesign.Brush.Primary.Dark}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource WarningForegroundBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ErrorResetButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
        <Setter Property="Padding" Value="12,4"/>
    </Style>

    <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="20"/>
        <Setter Property="Height" Value="40"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="TagButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="12"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="Padding" Value="8,2"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary.Container}"/>
    </Style>

    <Style x:Key="ModernActionButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFloatingActionMiniButton}">
    </Style>

    <Style x:Key="ModernToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignActionToggleButton}">
    </Style>

    <Style TargetType="Button" x:Key="IconButtonStyle" BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="40"/>
    </Style>

    <Style x:Key="HeaderIconButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="18"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="HeaderIconToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignActionToggleButton}">
        <Setter Property="Width" Value="36"/>
        <Setter Property="Height" Value="36"/>
        <Setter Property="Padding" Value="0"/>
    </Style>

    <Style x:Key="BillButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernFlatButtonStyle}">
        <Setter Property="Background" Value="#1A4CAF50"/>
        <Setter Property="BorderBrush" Value="#4CAF50"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#4CAF50"/>
    </Style>

    <Style x:Key="CoinButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernFlatButtonStyle}">
        <Setter Property="Background" Value="#1A2196F3"/>
        <Setter Property="BorderBrush" Value="#2196F3"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="#2196F3"/>
    </Style>

    <Style x:Key="DeviceCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource App.Brush.Close.Background}"/>
        <Setter Property="Foreground" Value="{DynamicResource App.Brush.Close.Foreground}"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="ModernTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignOutlinedTextBox}">
        <Setter Property="Margin" Value="0,8,0,8"/>
        <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="True"/>
        <Setter Property="AutomationProperties.Name" Value="" />
    </Style>

    <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource MaterialDesignOutlinedComboBox}">
        <Setter Property="Margin" Value="0,8,0,8"/>
    </Style>

    <Style x:Key="PrimaryToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource MaterialDesignActionToggleButton}">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.SurfaceVariant}"/>
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
    </Style>

    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox" BasedOn="{StaticResource MaterialDesignActionCheckBox}">
        <Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
    </Style>

    <Style x:Key="LogItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="2,1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <ContentPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TransactionListStyle" TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
        <Setter Property="Padding" Value="0,8"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <Style x:Key="BadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Style.Resources>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource WarningForegroundBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="FontSize" Value="11"/>
            </Style>
        </Style.Resources>
    </Style>

    <Style x:Key="AlertBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="0,0,8,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="AmountLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="Gray" />
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- DataGrid Styles -->
    <Style x:Key="App.Style.DataGridColumnHeader" TargetType="DataGridColumnHeader" BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}">
        <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.SurfaceVariant}"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="FontWeight" Value="Black"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <Style x:Key="App.Style.DataGridCell" TargetType="DataGridCell" BasedOn="{StaticResource MaterialDesignDataGridCell}">
        <Setter Property="Padding" Value="12,8"/>
    </Style>
</ResourceDictionary>
