<Window x:Class="CashChangerSimulator.UI.Wpf.DispenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CashChangerSimulator.UI.Wpf.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:DispenseViewModel}"
        Title="DISPENSE TERMINAL" Height="650" Width="420"
        WindowStartupLocation="CenterOwner"
        AutomationProperties.AutomationId="DispenseWindow"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.Foreground="{StaticResource OnBackgroundBrush}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        ResizeMode="CanResize" MinWidth="360" MinHeight="450">

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="DISPENSE TERMINAL" 
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" 
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontWeight="Black"/>
                <TextBlock Text="出金ターミナル" FontSize="10" Opacity="0.4" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <!-- Idle View -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusName.Value}" Value="Idle">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Simple Dispense -->
                        <Border Background="#0DFFFFFF" CornerRadius="8" Padding="16" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="AMOUNT DISPENSE" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,0,0,12"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" 
                                             materialDesign:HintAssist.Hint="Enter amount"
                                             Text="{Binding DispenseAmountInput.Value, UpdateSourceTrigger=PropertyChanged}" 
                                             Style="{StaticResource ModernTextBoxStyle}"
                                             FontSize="22" FontWeight="Light"
                                             AutomationProperties.AutomationId="DispenseBox"/>
                                    
                                    <Button Grid.Column="1" 
                                            Style="{StaticResource PrimaryButtonStyle}" 
                                            Command="{Binding DispenseCommand}" 
                                            VerticalAlignment="Center"
                                            Margin="12,0,0,0" Height="44" Width="44"
                                            AutomationProperties.AutomationId="DispenseButton">
                                        <materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Separator Background="#1AFFFFFF" Margin="0,4,0,20"/>

                        <!-- Bulk Dispense (Dialog) -->
                        <Button Style="{StaticResource ModernFlatButtonStyle}"
                                Command="{Binding ShowBulkDispenseCommand}"
                                HorizontalAlignment="Stretch" Height="44" Margin="0,0,0,12"
                                AutomationProperties.AutomationId="BulkDispenseShowButton">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PlaylistCheck" Margin="0,0,8,0"/>
                                <TextBlock Text="BULK DISPENSE" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Busy View -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusName.Value}" Value="Busy">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,60">
                            <TextBlock Text="DISPENSING..." FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding DispensingAmount.Value, StringFormat=¥{0:N0}}" FontSize="56" FontWeight="Thin" HorizontalAlignment="Center"/>
                            <ProgressBar IsIndeterminate="True" Margin="0,24" Width="240" Height="4" Foreground="{StaticResource PrimaryBrush}" BorderThickness="0" Background="Transparent"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Error View -->
                    <StackPanel>
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusName.Value}" Value="Error">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,40">
                            <materialDesign:PackIcon Kind="AlertCircle" Width="64" Height="64" Foreground="Red" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="DISPENSE ERROR" FontSize="24" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hardware check required." FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,12"/>
                            <Button Command="{Binding ClearErrorCommand}" Style="{StaticResource ModernFlatButtonStyle}" Foreground="Red" Margin="0,16" Height="44">
                                 <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Margin="0,0,8,0" />
                                    <TextBlock Text="CLEAR ERROR" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
